---
/**
 * 文档模版布局：左侧导航 + 主内容 + 右侧「本页目录」，参考 Starlight
 * https://starlight.astro.build/getting-started/
 */
import Base from "@/layouts/Base.astro";
import Breadcrumb from "@/components/Breadcrumb.astro";
import DocsSidebar from "@/components/DocsSidebar.astro";
import TableOfContents from "@/components/TableOfContents.astro";
import SidebarAd from "@/components/SidebarAd.astro";
import type { DocsNavSection } from "@/data/docsNav";
import type { Lang } from "@/i18n";

interface Props {
  title?: string;
  description?: string;
  /** 页面级关键词，覆盖全局 SITE_KEYWORDS */
  keywords?: string;
  breadcrumbs?: { name: string; url: string }[];
  /** 页面级额外结构化数据，传给 Base 输出 ld+json */
  structuredData?: Record<string, unknown>[];
  /** 侧栏导航分组 */
  sidebarSections: DocsNavSection[];
  /** 当前文档相对路径，用于高亮侧栏项 */
  currentPath?: string;
  /** 文档根路径（含 locale） */
  basePath: string;
  /** 侧栏折叠按钮文案 */
  sidebarMenuLabel?: string;
  /** 侧栏顶部搜索框占位文案，不传则不显示搜索框 */
  sidebarSearchPlaceholder?: string;
  /** 本页标题锚点，用于右侧「本页目录」；无则只显示左右两栏 */
  headings?: { depth: number; slug: string; text: string }[];
  /** 右侧 TOC 标题：本页目录 / On this page */
  tocLabel?: string;
}

const {
  title,
  description,
  keywords,
  breadcrumbs,
  structuredData,
  sidebarSections,
  currentPath = "",
  basePath,
  sidebarMenuLabel,
  sidebarSearchPlaceholder,
  headings = [],
  tocLabel,
} = Astro.props;
const locale = Astro.currentLocale as Lang;
const menuLabel = sidebarMenuLabel ?? (locale === "zh-cn" ? "本页导航" : "On this page");
const hasToc = headings.length > 0;
const rightTocLabel = tocLabel ?? (locale === "zh-cn" ? "本页目录" : "On this page");
---

<Base
  title={title}
  description={description}
  keywords={keywords}
  breadcrumbs={breadcrumbs}
  extraStructuredData={structuredData}
  contentWide={true}
>
  {breadcrumbs && breadcrumbs.length > 0 && (
    <Breadcrumb items={breadcrumbs} />
  )}
  <div class="l-docs" data-has-toc={hasToc}>
    <aside class="docs-sidebar-wrap">
      <DocsSidebar
        sections={sidebarSections}
        currentPath={currentPath}
        basePath={basePath}
        menuLabel={menuLabel}
        searchPlaceholder={sidebarSearchPlaceholder}
      />
    </aside>
    <div class="docs-content">
      <slot />
    </div>
    {hasToc && (
      <aside class="docs-toc-wrap">
        <TableOfContents headings={headings} label={rightTocLabel} placement="right" />
        <SidebarAd />
      </aside>
    )}
  </div>
</Base>

<style>
  .l-docs {
    display: grid;
    grid-template-columns: 220px 1fr;
    gap: var(--sp-l);
    align-items: start;
    max-inline-size: 1400px;
    margin-inline: auto;
    padding-inline: var(--sp-m);
  }
  .l-docs[data-has-toc="true"] {
    grid-template-columns: 220px minmax(0, 1fr) 200px;
    max-inline-size: 1400px;
  }
  .docs-sidebar-wrap {
    position: sticky;
    top: var(--sp-m);
    min-inline-size: 220px;
    overflow: visible;
  }
  .docs-content {
    min-inline-size: 0;
    max-inline-size: 900px;
  }
  .l-docs[data-has-toc="true"] .docs-content {
    max-inline-size: none;
  }
  .docs-toc-wrap {
    position: sticky;
    top: var(--sp-m);
    align-self: start;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .docs-content :global(h1) {
    font-size: 2rem;
    font-weight: 700;
    margin-block-end: var(--sp-m);
    letter-spacing: -0.02em;
  }
  .docs-content :global(h2) {
    font-size: 1.35rem;
    font-weight: 600;
    margin-block: var(--sp-l) var(--sp-s);
    padding-block-end: 0.35em;
    border-block-end: 1px solid color-mix(in srgb, var(--color-theme) 18%, transparent);
  }
  .docs-content :global(h3) {
    font-size: 1.15rem;
    font-weight: 600;
    margin-block: var(--sp-m) var(--sp-s);
  }
  .docs-content :global(p) {
    margin-block: 0.85em 0;
    line-height: 1.7;
  }
  .docs-content :global(ul),
  .docs-content :global(ol) {
    padding-inline-start: 1.5em;
    margin-block: 0.75em 0;
  }
  .docs-content :global(li) {
    margin-block: 0.3em 0;
  }
  .docs-content :global(a) {
    color: var(--color-theme);
    text-decoration: underline;
  }
  .docs-content :global(a:hover) {
    text-decoration-thickness: 2px;
  }
  .docs-content :global(code) {
    font-size: 0.9em;
    padding: 0.15em 0.4em;
    border-radius: 6px;
    background: color-mix(in srgb, var(--color-theme) 10%, transparent);
    border: 1px solid color-mix(in srgb, var(--color-theme) 22%, transparent);
  }
  .docs-content :global(pre) {
    overflow-x: auto;
    padding: var(--sp-m);
    border-radius: 10px;
    background: color-mix(in srgb, var(--color-main) 8%, var(--color-base));
    border: 1px solid color-mix(in srgb, var(--color-theme) 15%, transparent);
    margin-block: 1em 0;
  }
  .docs-content :global(pre code) {
    padding: 0;
    background: none;
    border: none;
  }

  @media (width < 1100px) {
    .l-docs[data-has-toc="true"] {
      grid-template-columns: 220px 1fr;
    }
    .docs-toc-wrap {
      display: none;
    }
  }
  @media (width < 768px) {
    .l-docs {
      grid-template-columns: 1fr;
      gap: var(--sp-m);
    }
    .l-docs[data-has-toc="true"] {
      grid-template-columns: 1fr;
    }
    .docs-sidebar-wrap {
      position: static;
    }
    .docs-content {
      max-inline-size: none;
    }
  }
</style>
