---
/**
 * 文档页左侧导航，用于 Docs 布局模版。
 * 接收导航分组与当前路径，高亮当前项；移动端可折叠。
 */
import type { DocsNavSection } from "@/data/docsNav";

interface Props {
  sections: DocsNavSection[];
  /** 当前页路径（相对 docs 根），如 "" 或 "getting-started" */
  currentPath: string;
  /** 文档根路径（含 locale），如 "/en/docs" 或 "/zh-cn/wiki" */
  basePath: string;
  /** 移动端折叠按钮文案 */
  menuLabel?: string;
  /** 检索框占位文案，传入则显示侧栏顶部搜索框（检索词条） */
  searchPlaceholder?: string;
}

const { sections, currentPath, basePath, menuLabel = "On this page", searchPlaceholder } = Astro.props;

const normalize = (p: string) => p.replace(/\/$/, "") || "";
const current = normalize(currentPath);

const href = (itemHref: string) => {
  const seg = itemHref ? `/${itemHref}` : "";
  return `${basePath}${seg}`.replace(/\/+/g, "/") + "/";
};
const isActive = (itemHref: string) => normalize(itemHref) === current;
---

<aside class="docs-sidebar" aria-label="Documentation navigation">
  <div class="docs-sidebar-inner">
    {searchPlaceholder && (
      <div class="docs-sidebar-search">
        <label for="docs-sidebar-search-input" class="visually-hidden">检索词条</label>
        <input
          type="search"
          id="docs-sidebar-search-input"
          class="docs-sidebar-search-input"
          placeholder={searchPlaceholder}
          autocomplete="off"
          aria-label="检索词条"
        />
      </div>
    )}
    <button type="button" class="docs-sidebar-toggle" aria-expanded="false" aria-controls="docs-sidebar-nav" id="docs-sidebar-toggle">
      <span class="docs-sidebar-toggle-text">{menuLabel}</span>
      <span class="docs-sidebar-toggle-icon" aria-hidden="true">
        <svg xmlns="http://www.w3.org/2000/svg" width="1.2em" height="1.2em" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"/></svg>
      </span>
    </button>
    <nav class="docs-sidebar-nav" id="docs-sidebar-nav">
      {sections.map((section) => (
        <div class="docs-sidebar-section" data-section>
          {section.title && (
            <h3 class="docs-sidebar-section-title">{section.title}</h3>
          )}
          <ul class="docs-sidebar-list">
            {section.items.map((item) => {
              const active = isActive(item.href);
              const searchText = `${item.label} ${item.href}`.toLowerCase();
              return (
                <li>
                  <a
                    href={href(item.href)}
                    class:list={["docs-sidebar-link", active && "docs-sidebar-link--active"]}
                    aria-current={active ? "page" : undefined}
                    data-search={searchText}
                  >
                    {item.label}
                  </a>
                </li>
              );
            })}
          </ul>
        </div>
      ))}
    </nav>
  </div>
</aside>

<style>
  .docs-sidebar {
    align-self: start;
  }
  .docs-sidebar-inner {
    border-inline-start: 3px solid color-mix(in srgb, var(--color-theme) 35%, transparent);
    border-radius: 0 10px 10px 0;
    background: color-mix(in srgb, var(--color-base) 96%, var(--color-main));
    padding-inline-start: 0;
  }
  .docs-sidebar-toggle {
    display: none;
    width: 100%;
    list-style: none;
    padding: var(--sp-s) var(--sp-m);
    font-weight: 600;
    cursor: pointer;
    color: var(--color-theme);
    align-items: center;
    gap: 0.5rem;
    border: none;
    background: transparent;
    font-size: inherit;
    font-family: inherit;
    text-align: start;
  }
  .docs-sidebar-toggle-icon {
    margin-inline-start: auto;
    transition: transform 0.2s ease;
  }
  .docs-sidebar-inner.is-open .docs-sidebar-toggle-icon {
    transform: rotate(180deg);
  }
  .docs-sidebar-nav {
    display: block;
    padding: var(--sp-s) var(--sp-m);
  }
  .docs-sidebar-section {
    margin-block-end: var(--sp-m);
  }
  .docs-sidebar-section:last-child {
    margin-block-end: 0;
  }
  .docs-sidebar-section-title {
    font-size: 1.1rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: color-mix(in srgb, var(--color-main) 50%, transparent);
    margin: 0 0 var(--sp-s);
    padding-block-end: 0.35rem;
    border-block-end: 1px solid color-mix(in srgb, var(--color-theme) 12%, transparent);
  }
  .docs-sidebar-search {
    padding: var(--sp-s) var(--sp-m);
    padding-block-end: 0;
  }
  .docs-sidebar-search-input {
    width: 100%;
    padding: 0.5em 0.75em;
    font-size: 0.9rem;
    font-family: inherit;
    color: var(--color-main);
    background: color-mix(in srgb, var(--color-main) 12%, var(--color-base));
    border: 1px solid color-mix(in srgb, var(--color-theme) 25%, transparent);
    border-radius: 8px;
    outline: none;
  }
  .docs-sidebar-search-input::placeholder {
    color: color-mix(in srgb, var(--color-main) 55%, transparent);
  }
  .docs-sidebar-search-input:focus {
    border-color: var(--color-theme);
    box-shadow: 0 0 0 2px color-mix(in srgb, var(--color-theme) 25%, transparent);
  }
  .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
  .docs-sidebar-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .docs-sidebar-list li {
    margin: 0;
  }
  .docs-sidebar-link {
    display: block;
    padding: 0.4em 0.6em;
    margin-block: 0.15em 0;
    font-size: 0.9375rem;
    font-weight: 500;
    color: color-mix(in srgb, var(--color-main) 88%, transparent);
    text-decoration: none;
    border-radius: 8px;
    transition: background 0.2s ease, color 0.2s ease;
  }
  .docs-sidebar-link:hover {
    color: var(--color-theme);
    background: color-mix(in srgb, var(--color-theme) 8%, transparent);
  }
  .docs-sidebar-link--active {
    color: var(--color-theme);
    font-weight: 600;
    background: color-mix(in srgb, var(--color-theme) 12%, transparent);
  }
  .docs-sidebar-link--active:hover {
    background: color-mix(in srgb, var(--color-theme) 16%, transparent);
  }

  @media (width < 768px) {
    .docs-sidebar-toggle {
      display: flex;
    }
    .docs-sidebar-nav {
      padding-block-start: 0;
      display: none;
    }
    .docs-sidebar-inner.is-open .docs-sidebar-nav {
      display: block;
    }
  }
</style>

<script>
  function initDocsSidebar() {
    const btn = document.getElementById("docs-sidebar-toggle");
    if (btn) {
      const inner = btn.closest(".docs-sidebar-inner");
      if (inner) {
        btn.addEventListener("click", () => {
          inner.classList.toggle("is-open");
          btn.setAttribute("aria-expanded", inner.classList.contains("is-open") ? "true" : "false");
        });
      }
    }
    const searchInput = document.getElementById("docs-sidebar-search-input");
    if (searchInput) {
      searchInput.addEventListener("input", () => {
        const q = (searchInput as HTMLInputElement).value.trim().toLowerCase();
        const sections = document.querySelectorAll(".docs-sidebar-section[data-section]");
        sections.forEach((section) => {
          const links = section.querySelectorAll<HTMLAnchorElement>(".docs-sidebar-link[data-search]");
          let visible = 0;
          links.forEach((a) => {
            const match = !q || (a.getAttribute("data-search") ?? "").includes(q);
            (a as HTMLElement).style.display = match ? "" : "none";
            if (match) visible++;
          });
          (section as HTMLElement).style.display = visible > 0 || !q ? "" : "none";
        });
      });
    }
  }
  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initDocsSidebar);
  } else {
    initDocsSidebar();
  }
</script>
