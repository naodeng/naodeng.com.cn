---
/**
 * 学习工作流程组件
 * 展示学习步骤和流程
 */
interface Props {
  locale: string;
}

const { locale } = Astro.props;

const content = {
  'zh-cn': {
    title: '🔄 学习工作流程',
    subtitle: '三步开始你的自动化测试之旅',
    steps: [
      {
        number: '1',
        title: '选择测试框架',
        description: '根据你的技术栈和测试需求，选择对应的测试框架',
        details: [
          '接口测试：Postman、Pytest、Rest Assured 等',
          'UI 测试：Playwright、Cypress 等',
          '性能测试：K6、Gatling 等',
        ],
      },
      {
        number: '2',
        title: '跟随学习路径',
        description: '按照系统化的学习路径，从入门到进阶',
        details: [
          '环境搭建和配置',
          '编写第一个测试脚本',
          '进阶技巧和最佳实践',
        ],
      },
      {
        number: '3',
        title: '实践和集成',
        description: '通过 Demo 项目实践，并集成到 CI/CD 流程',
        details: [
          '克隆 GitHub Demo 项目',
          '本地运行和调试',
          '集成到 CI/CD 流程',
        ],
      },
    ],
  },
  'en': {
    title: '🔄 Learning Workflow',
    subtitle: 'Start your test automation journey in three steps',
    steps: [
      {
        number: '1',
        title: 'Choose Framework',
        description: 'Select the testing framework based on your tech stack and needs',
        details: [
          'API Testing: Postman, Pytest, Rest Assured, etc.',
          'UI Testing: Playwright, Cypress, etc.',
          'Performance Testing: K6, Gatling, etc.',
        ],
      },
      {
        number: '2',
        title: 'Follow Learning Path',
        description: 'Follow systematic learning paths from beginner to advanced',
        details: [
          'Environment setup and configuration',
          'Write your first test script',
          'Advanced techniques and best practices',
        ],
      },
      {
        number: '3',
        title: 'Practice & Integrate',
        description: 'Practice with demo projects and integrate into CI/CD',
        details: [
          'Clone GitHub demo projects',
          'Run and debug locally',
          'Integrate into CI/CD pipeline',
        ],
      },
    ],
  },
};

const text = content[locale as keyof typeof content] || content['en'];
---

<section class="learning-workflow">
  <div class="learning-workflow__header">
    <h2 class="learning-workflow__title">{text.title}</h2>
    <p class="learning-workflow__subtitle">{text.subtitle}</p>
  </div>

  <div class="workflow-steps">
    {text.steps.map((step, index) => (
      <div class="workflow-step">
        <div class="workflow-step__number">{step.number}</div>
        <div class="workflow-step__content">
          <h3 class="workflow-step__title">{step.title}</h3>
          <p class="workflow-step__description">{step.description}</p>
          <ul class="workflow-step__details">
            {step.details.map((detail) => (
              <li>{detail}</li>
            ))}
          </ul>
        </div>
        {index < text.steps.length - 1 && (
          <div class="workflow-step__arrow" aria-hidden="true">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M5 12h14M12 5l7 7-7 7"/>
            </svg>
          </div>
        )}
      </div>
    ))}
  </div>
</section>

<style>
  .learning-workflow {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 16px;
    padding: 1.75rem 1.5rem;
  }

  .learning-workflow__header {
    text-align: center;
    margin-bottom: 1.75rem;
  }

  .learning-workflow__title {
    font-size: clamp(1.25rem, 2.5vw, 1.75rem);
    font-weight: 800;
    color: var(--color-main);
    margin: 0 0 0.5rem 0;
  }

  .learning-workflow__subtitle {
    font-size: 0.9rem;
    color: color-mix(in srgb, var(--color-main) 65%, transparent);
    margin: 0;
  }

  .workflow-steps {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
  }

  .workflow-step {
    position: relative;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 16px;
    padding: 1.5rem;
    transition: var(--transition-base);
  }

  .workflow-step:hover {
    border-color: var(--color-theme);
    transform: translateY(-4px);
    box-shadow: 0 0 20px var(--glow-theme);
  }

  .workflow-step__number {
    width: 48px;
    height: 48px;
    background: var(--color-theme);
    color: var(--color-base);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.5rem;
    font-weight: 800;
    margin-bottom: 1.5rem;
    font-family: var(--english-font);
  }

  .workflow-step__content {
    flex: 1;
  }

  .workflow-step__title {
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--color-theme);
    margin: 0 0 0.75rem 0;
  }

  .workflow-step__description {
    font-size: 0.95rem;
    line-height: 1.6;
    color: var(--color-main);
    opacity: 0.8;
    margin: 0 0 1rem 0;
  }

  .workflow-step__details {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .workflow-step__details li {
    font-size: 0.875rem;
    line-height: 1.6;
    color: var(--color-main);
    opacity: 0.7;
    padding-left: 1.25rem;
    position: relative;
    margin-bottom: 0.5rem;
  }

  .workflow-step__details li::before {
    content: "▹";
    position: absolute;
    left: 0;
    color: var(--color-theme);
    font-weight: bold;
  }

  .workflow-step__arrow {
    display: none;
  }

  @media (max-width: 968px) {
    .workflow-steps {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }

    .workflow-step__arrow {
      display: block;
      text-align: center;
      color: var(--color-theme);
      margin: 1rem 0;
      transform: rotate(90deg);
    }
  }

  @media (max-width: 768px) {
    .learning-workflow {
      margin: 3rem 0;
      padding: 2rem 1rem;
      border-radius: 16px;
    }

    .learning-workflow__header {
      margin-bottom: 2rem;
    }

    .learning-workflow__title {
      font-size: 1.5rem;
    }

    .learning-workflow__subtitle {
      font-size: 1rem;
    }

    .workflow-step {
      padding: 1.5rem;
    }

    .workflow-step__number {
      width: 40px;
      height: 40px;
      font-size: 1.25rem;
      margin-bottom: 1rem;
    }

    .workflow-step__title {
      font-size: 1.1rem;
    }

    .workflow-step__description {
      font-size: 0.9rem;
    }

    .workflow-step__details li {
      font-size: 0.85rem;
    }
  }
</style>
