---
/**
 * Guild 页面头部组件
 */
import { getGuildConfig } from '../../config/guild.config';

interface Props {
  locale: string;
}

const { locale } = Astro.props;
const guildConfig = getGuildConfig(locale);

const isZh = locale === 'zh-cn';

const content = {
  'zh-cn': {
    badge: '🚀 测试自动化指南',
    title: '让自动化测试成为你的超能力',
    description: '系统化的学习路径，从入门到进阶，涵盖接口测试、UI 测试和性能测试。选择你感兴趣的框架，开始你的自动化测试之旅。',
    stats: { testTypes: '测试类型', frameworks: '测试框架', learningPaths: '学习路径' },
  },
  'en': {
    badge: '🚀 Test Automation Guild',
    title: 'Make Test Automation Your Superpower',
    description: 'Systematic learning paths from beginner to advanced, covering API testing, UI testing, and performance testing. Choose your framework and start your journey.',
    stats: { testTypes: 'Test Types', frameworks: 'Frameworks', learningPaths: 'Learning Paths' },
  },
};

const text = content[locale as keyof typeof content] ?? content['en'];

const totalFrameworks = guildConfig.testTypes.reduce((sum, type) => sum + type.frameworks.length, 0);
const totalTestTypes = guildConfig.testTypes.length;
---

<div class="guild-hero">
  <div class="guild-hero__inner">
    <div class="guild-hero__badge">{text.badge}</div>
    <h1 class="guild-hero__title">{text.title}</h1>
    <p class="guild-hero__description">{text.description}</p>

    <div class="guild-hero__stats" role="list" aria-label={isZh ? '指南统计' : 'Guide stats'}>
      <div class="stat-item" role="listitem">
        <span class="stat-item__value">{totalTestTypes}</span>
        <span class="stat-item__label">{text.stats.testTypes}</span>
      </div>
      <div class="stat-sep" aria-hidden="true"></div>
      <div class="stat-item" role="listitem">
        <span class="stat-item__value">{totalFrameworks}</span>
        <span class="stat-item__label">{text.stats.frameworks}</span>
      </div>
      <div class="stat-sep" aria-hidden="true"></div>
      <div class="stat-item" role="listitem">
        <span class="stat-item__value">60+</span>
        <span class="stat-item__label">{text.stats.learningPaths}</span>
      </div>
    </div>
  </div>
</div>

<style>
  .guild-hero {
    padding: 3rem 2rem 2.5rem;
    border-radius: 20px;
    background: color-mix(in srgb, var(--color-theme) 3%, var(--color-base));
    border: 1px solid color-mix(in srgb, var(--color-theme) 12%, transparent);
    position: relative;
    overflow: hidden;
    text-align: center;
  }

  .guild-hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse 70% 50% at 50% 0%, color-mix(in srgb, var(--color-theme) 10%, transparent), transparent 70%);
    pointer-events: none;
  }

  .guild-hero__inner {
    position: relative;
    z-index: 1;
    max-width: 700px;
    margin: 0 auto;
  }

  .guild-hero__badge {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.3em 0.9em;
    border-radius: 999px;
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    color: var(--color-theme);
    background: color-mix(in srgb, var(--color-theme) 10%, transparent);
    border: 1px solid color-mix(in srgb, var(--color-theme) 20%, transparent);
    margin-bottom: 1rem;
  }

  .guild-hero__title {
    font-size: clamp(1.75rem, 4vw, 2.75rem);
    font-weight: 900;
    letter-spacing: -0.03em;
    line-height: 1.15;
    margin: 0 0 1rem;
    background: linear-gradient(135deg, var(--color-main) 20%, color-mix(in srgb, var(--color-theme) 80%, var(--color-main)));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .guild-hero__description {
    font-size: 1rem;
    line-height: 1.75;
    color: color-mix(in srgb, var(--color-main) 70%, transparent);
    margin: 0 auto 2rem;
    max-width: 580px;
  }

  .guild-hero__stats {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1.5rem;
    padding-top: 1.5rem;
    border-top: 1px solid color-mix(in srgb, var(--color-theme) 15%, transparent);
    flex-wrap: wrap;
  }

  .stat-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.2rem;
  }

  .stat-item__value {
    font-size: 2rem;
    font-weight: 800;
    color: var(--color-theme);
    line-height: 1;
    font-family: var(--english-font);
  }

  .stat-item__label {
    font-size: 0.78rem;
    color: color-mix(in srgb, var(--color-main) 60%, transparent);
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .stat-sep {
    width: 1px;
    height: 2rem;
    background: color-mix(in srgb, var(--color-border) 80%, transparent);
  }

  @media (max-width: 600px) {
    .guild-hero {
      padding: 2rem 1.25rem 1.75rem;
    }

    .stat-sep {
      display: none;
    }

    .guild-hero__stats {
      gap: 1.25rem;
    }

    .stat-item__value {
      font-size: 1.6rem;
    }
  }
</style>
