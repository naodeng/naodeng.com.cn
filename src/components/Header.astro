---
import LocaleSelect from "@/components/i18n/LocaleSelect.astro";
import { useTranslations, type Lang } from "@/i18n";
import { getRelativeLocaleUrl } from "astro:i18n";
import { SITE_TITLE, SITE_SLOGAN, NAV_HOME, NAV_ABOUT, NAV_PROJECTS, NAV_QA_WIKI, NAV_AI_WIKI, NAV_GUILD, NAV_QA_PROMPTS, NAV_SPONSOR, NAV_SEARCH } from "@/consts";

const t = useTranslations(Astro.currentLocale as Lang);
const locale = Astro.currentLocale as Lang;

const isActive = (path: string) =>
  getRelativeLocaleUrl(locale, path) === Astro.url.pathname;
const pathWithoutLang = Astro.url.pathname.replace(/^\/[a-zA-Z-]+/, "") || "/";
const isWikiSection = () => pathWithoutLang === "/wiki" || pathWithoutLang.startsWith("/wiki/");
const isAiWikiSection = () => pathWithoutLang === "/AIWiki" || pathWithoutLang.startsWith("/AIWiki/");
const isGuildSection = () => pathWithoutLang === "/guild" || pathWithoutLang.startsWith("/guild/");
const isPromptsSection = () => pathWithoutLang === "/prompts" || pathWithoutLang.startsWith("/prompts/");
const siteTitle = t(SITE_TITLE);
---

<header class="l-header">
  <div class:list={["site-brand", { "site-brand--en": locale === "en" }]}>
    <div class="site-brand-row">
      <h1>
        <a href={getRelativeLocaleUrl(locale, "/")}>
          <img src="/favicon.svg" alt="" class="site-logo" width="36" height="36" />
          {locale === "zh-cn" ? (
            <span class="site-title-cobrand" aria-label={siteTitle}>
              <span>软件测试同学</span>
              <span class="site-title-cobrand-x" aria-hidden="true">X</span>
              <span>naodeng</span>
            </span>
          ) : (
            <span>{siteTitle}</span>
          )}
        </a>
      </h1>
      {locale !== "en" && <p class="site-slogan">{t(SITE_SLOGAN)}</p>}
    </div>
  </div>

  <nav class="l-content">
    <ul>
      <li>
        <a
          href={getRelativeLocaleUrl(locale, "/")}
          class={isActive("/") ? "active" : null}
        >
          {t(NAV_HOME)}
        </a>
      </li>
      <li>
        <a
          href={getRelativeLocaleUrl(locale, "/blog")}
          class={isActive("/blog") ? "active" : null}
        >
          {t({ en: "Blog", "zh-cn": "博客" })}
        </a>
      </li>
      <li>
        {locale === "zh-cn" ? (
          <a
            href={getRelativeLocaleUrl(locale, "/wiki")}
            class={isWikiSection() ? "active" : null}
          >
            {t(NAV_QA_WIKI)}
          </a>
        ) : (
          <a
            href="https://ray.run/wiki"
            target="_blank"
            rel="noopener noreferrer"
          >
            {t(NAV_QA_WIKI)}
          </a>
        )}
      </li>
      <li>
        <a
          href={getRelativeLocaleUrl(locale, "/AIWiki")}
          class={isAiWikiSection() ? "active" : null}
        >
          {t(NAV_AI_WIKI)}
        </a>
      </li>
      <li>
        <a
          href={getRelativeLocaleUrl(locale, "/guild")}
          class={isGuildSection() ? "active" : null}
        >
          {t(NAV_GUILD)}
        </a>
      </li>
      <li>
        <a
          href={getRelativeLocaleUrl(locale, "/prompts")}
          class={isPromptsSection() ? "active" : null}
        >
          {t(NAV_QA_PROMPTS)}
        </a>
      </li>
      <li>
        <a
          href={getRelativeLocaleUrl(locale, "/projects")}
          class={isActive("/projects") ? "active" : null}
        >
          {t(NAV_PROJECTS)}
        </a>
      </li>
      <li>
        <a
          href={getRelativeLocaleUrl(locale, "/sponsor")}
          class={isActive("/sponsor") ? "active" : null}
        >
          {t(NAV_SPONSOR)}
        </a>
      </li>
      <li>
        <a
          href={getRelativeLocaleUrl(locale, "/about")}
          class={isActive("/about") ? "active" : null}
        >
          {t(NAV_ABOUT)}
        </a>
      </li>
      <li class="nav-tool">
        <LocaleSelect compact />
      </li>
      <li class="nav-tool">
        <button type="button" class="btn-icon" aria-label={t(NAV_SEARCH)} data-search-open>
          <span class="material-icons-sharp" aria-hidden="true">search</span>
        </button>
      </li>
    </ul>
  </nav>
</header>

<style>
  .l-header {
    display: grid;
    place-items: center;
    gap: 0.5rem;
    padding-block: 0.7rem 0.55rem;
    border-block-end: 1px solid color-mix(in srgb, var(--color-theme) 12%, transparent);
    background: linear-gradient(
      180deg,
      color-mix(in srgb, var(--color-theme) 3%, var(--color-base)) 0%,
      var(--color-base) 100%
    );
  }
  .site-brand {
    width: 100%;
    display: flex;
    justify-content: center;
  }
  .site-brand--en .site-brand-row {
    column-gap: 0.8rem;
    row-gap: 0.18rem;
  }
  .site-brand-row {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    justify-content: center;
    column-gap: 1.1rem;
    row-gap: 0.28rem;
    max-width: min(100%, 76rem);
  }
  .site-slogan {
    margin: 0;
    display: inline-block;
    max-width: min(100%, 34rem);
    white-space: nowrap;
    padding: 0;
    font-size: 0.76rem;
    font-weight: 560;
    font-family: var(--english-font);
    color: color-mix(in srgb, var(--color-theme) 74%, white 12%);
    letter-spacing: 0.035em;
    line-height: 1.4;
    text-align: center;
    opacity: 0.76;
    overflow-wrap: break-word;
  }
  h1 {
    margin: 0;
    font-size: 31px;
    font-family: var(--english-font);
    font-weight: 880;
    letter-spacing: -0.04em;
    line-height: 1;
  }
  @media (width < 480px) {
    h1 {
      font-size: 24px;
    }
  }
  @media (width < 900px) {
    .site-brand-row {
      flex-wrap: wrap;
      flex-direction: column;
      column-gap: 0;
    }
    .site-slogan {
      max-width: min(100%, 34rem);
      white-space: normal;
      text-align: center;
    }
  }
  h1 a {
    display: inline-flex;
    align-items: center;
    gap: 0.55em;
    color: var(--color-main);
    text-decoration: none;
    transition: color 0.2s ease, opacity 0.2s ease;
  }
  .site-brand--en h1 {
    font-size: 30px;
    letter-spacing: -0.03em;
  }
  .site-brand--en h1 a {
    gap: 0.48em;
  }
  .site-title-cobrand {
    display: inline-flex;
    align-items: center;
    gap: 0.32em;
    white-space: nowrap;
    line-height: 0.96;
  }
  .site-title-cobrand-x {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 1.24em;
    height: 1.24em;
    padding-inline: 0.16em;
    margin-inline: 0.08em 0.12em;
    font-size: 0.46em;
    font-weight: 800;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-theme);
    background: color-mix(in srgb, var(--color-theme) 7%, transparent);
    border: 1px solid color-mix(in srgb, var(--color-theme) 16%, transparent);
    border-radius: 999px;
    box-shadow: inset 0 1px 0 color-mix(in srgb, white 10%, transparent);
    transform: translateY(-0.12em);
  }
  h1 a:hover {
    opacity: 0.9;
    color: var(--color-theme);
  }
  h1 a .site-logo {
    flex-shrink: 0;
    width: 42px;
    height: 42px;
    object-fit: contain;
    margin-top: 0.08em;
    transition: transform 0.2s ease, filter 0.2s ease;
  }
  h1 a:hover .site-logo {
    transform: scale(1.05);
    filter: drop-shadow(0 4px 10px color-mix(in srgb, var(--color-theme) 18%, transparent));
  }
  @media (width < 480px) {
    h1 a .site-logo {
      width: 30px;
      height: 30px;
    }
  }
  nav {
    display: flex;
    align-items: center;
    gap: 0;
  }
  nav ul {
    display: flex;
    flex-wrap: nowrap;
    align-items: center;
    gap: 0.65rem;
    margin-block-start: 0;
  }
  @media (max-width: 880px) {
    nav ul {
      flex-wrap: wrap;
      justify-content: center;
      gap: 0.45rem 0.55rem;
    }
  }
  nav a {
    font-size: 0.98rem;
    font-weight: 580;
    letter-spacing: 0.04em;
    padding: 0.35em 0;
    border-radius: 0;
    white-space: nowrap;
    text-decoration: none;
    color: color-mix(in srgb, var(--color-main) 72%, transparent);
    transition: color 0.2s ease, opacity 0.2s ease;
    position: relative;
  }
  nav a:hover,
  nav a:active,
  nav a:focus-visible {
    color: var(--color-theme);
    opacity: 1;
  }
  nav a:focus-visible {
    outline: 2px solid var(--color-theme);
    outline-offset: 2px;
  }
  nav a.active {
    pointer-events: none;
    color: var(--color-theme);
    font-weight: 700;
  }
  nav a.active::after {
    content: '';
    position: absolute;
    bottom: -0.32rem;
    left: 0;
    right: 0;
    height: 2px;
    border-radius: 2px;
    background: var(--color-theme);
  }
  nav li {
    display: flex;
    align-items: center;
    flex-shrink: 0;
  }
  .nav-tool {
    display: flex;
    align-items: center;
    margin-inline-start: 0.2rem;
    padding-inline-start: 0.8rem;
    border-inline-start: 1px solid color-mix(in srgb, var(--color-theme) 10%, transparent);
  }
  .btn-icon {
    display: inline-flex;
    flex-wrap: nowrap;
    align-items: center;
    justify-content: center;
    height: 34px;
    min-width: 34px;
    padding-inline: 0.45rem;
    white-space: nowrap;
    font: inherit;
    font-size: 0.95rem;
    font-weight: 600;
    color: color-mix(in srgb, var(--color-main) 78%, transparent);
    background: transparent;
    border: 1px solid transparent;
    border-radius: 999px;
    cursor: pointer;
    transition: color 0.2s ease, background 0.2s ease, border-color 0.2s ease;
  }
  .btn-icon:hover,
  .btn-icon:focus-visible {
    color: var(--color-theme);
    background: color-mix(in srgb, var(--color-theme) 7%, transparent);
    border-color: color-mix(in srgb, var(--color-theme) 14%, transparent);
  }
  .btn-icon:focus-visible {
    outline: none;
  }
  .btn-icon .material-icons-sharp {
    font-size: 20px;
    color: var(--color-theme);
    opacity: 0.9;
    flex-shrink: 0;
  }
  nav a .material-icons-sharp {
    opacity: 0.7;
    margin-inline-start: -0.15em;
    font-size: 0.95em;
  }
</style>
