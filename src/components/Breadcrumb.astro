---
interface Props {
  items: { name: string; url: string }[];
}

const { items } = Astro.props;
---

{items.length > 0 ? (
  <nav class="breadcrumb" aria-label="Breadcrumb">
    <ol class="breadcrumb-list">
      {items.map((item, i) => {
        const isLast = i === items.length - 1;
        const isHome = i === 0;
        return (
          <li class="breadcrumb-item">
            {!isLast ? (
              <a href={item.url} class="breadcrumb-link">
                {isHome ? (
                  <svg class="home-icon" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
                ) : (
                  item.name
                )}
              </a>
            ) : (
              <span class="breadcrumb-current" aria-current="page" title={item.name}>
                {item.name}
              </span>
            )}
            {!isLast && (
              <span class="breadcrumb-sep" aria-hidden="true">/</span>
            )}
          </li>
        );
      })}
    </ol>
  </nav>
) : null}

<style>
  .breadcrumb {
    margin-block-end: var(--sp-m, 1.5rem);
    padding-block: 0.5rem;
  }
  .breadcrumb-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0;
    font-size: 0.8rem;
    color: color-mix(in srgb, var(--color-main) 50%, transparent);
  }
  .breadcrumb-item {
    display: inline-flex;
    align-items: center;
  }
  .breadcrumb-link {
    color: color-mix(in srgb, var(--color-main) 55%, transparent);
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    transition: color 0.15s;
  }
  .breadcrumb-link:hover {
    color: var(--color-theme);
  }
  .home-icon {
    display: block;
    vertical-align: middle;
  }
  .breadcrumb-sep {
    margin-inline: 0.5rem;
    color: color-mix(in srgb, var(--color-main) 30%, transparent);
    user-select: none;
    font-weight: 300;
  }
  .breadcrumb-current {
    color: color-mix(in srgb, var(--color-main) 75%, transparent);
    max-width: 40ch;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    display: inline-block;
  }
</style>
