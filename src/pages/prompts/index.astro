---
// Redirect /prompts/ to the locale-prefixed prompts page based on browser language
import { LOCALES, DEFAULT_LOCALE } from "@/i18n";

const langs = Object.keys(LOCALES);
const baseUrl = import.meta.env.PROD ? Astro.site : "/";
const defaultLocale = DEFAULT_LOCALE;
---

<html lang={DEFAULT_LOCALE}>
  <head>
    <meta charset="UTF-8" />
    <title>redirect...</title>
    <meta name="robots" content="noindex, follow" />
    <noscript>
      <meta http-equiv="refresh" content={`0;url=${baseUrl + DEFAULT_LOCALE}/prompts/`} />
    </noscript>
    <script is:inline define:vars={{ langs, baseUrl, defaultLocale }}>
      (function () {
        if (localStorage.selectedLang && langs.includes(localStorage.selectedLang)) {
          location.replace(baseUrl + localStorage.selectedLang + "/prompts/");
          return;
        }
        var preferred = navigator.language || navigator.userLanguage || "";
        var list = navigator.languages && navigator.languages.length
          ? [preferred].concat(Array.from(navigator.languages))
          : [preferred];
        for (var i = 0; i < list.length; i++) {
          var raw = (list[i] || "").toLowerCase();
          if (langs.includes(raw)) {
            location.replace(baseUrl + raw + "/prompts/");
            return;
          }
          var primary = raw.split("-")[0];
          if (primary === "zh") {
            location.replace(baseUrl + "zh-cn/prompts/");
            return;
          }
          if (langs.includes(primary)) {
            location.replace(baseUrl + primary + "/prompts/");
            return;
          }
        }
        location.replace(baseUrl + defaultLocale + "/prompts/");
      })();
    </script>
  </head>
  <body>
    <p>redirect...</p>
  </body>
</html>
