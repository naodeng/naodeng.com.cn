---
/**
 * 测试自动化指南 - 中文概览页
 */
import Base from '@/layouts/Base.astro';
import { getGuildConfig } from '../../../config/guild.config';
import GuildHero from '../../../components/guild/GuildHero.astro';
import GuildFeatures from '../../../components/guild/GuildFeatures.astro';
import LearningWorkflow from '../../../components/guild/LearningWorkflow.astro';
import TestTypeSection from '../../../components/guild/TestTypeSection.astro';
import GoogleAd from '../../../components/GoogleAd.astro';
import { GUILD_PAGE_DESCRIPTION, GUILD_PAGE_KEYWORDS } from '@/consts';

const locale = 'zh-cn';
const guildConfig = getGuildConfig(locale);

const title = '测试自动化指南';
const description = GUILD_PAGE_DESCRIPTION['zh-cn'];
const keywords = GUILD_PAGE_KEYWORDS['zh-cn'];

const breadcrumbs = [
  { name: '首页', url: `/${locale}/` },
  { name: '指南', url: `/${locale}/guild/` },
];

const siteOrigin = 'https://inaodeng.com';
const guildSchema = {
  "@context": "https://schema.org",
  "@type": "Course",
  name: title,
  description,
  url: `${siteOrigin}/zh-cn/guild/`,
  inLanguage: "zh-CN",
  provider: {
    "@type": "Person",
    name: "Nao Deng",
    url: siteOrigin,
  },
  teaches: ["接口测试", "UI测试", "性能测试", "测试自动化"],
};

const visibleTestTypes = guildConfig.testTypes.filter(t => t.id !== 'ui-testing');
---

<Base title={title} description={description} keywords={keywords} breadcrumbs={breadcrumbs} extraStructuredData={[guildSchema]}>
  <div class="l-content guild-page">

    <!-- Hero card -->
    <GuildHero locale={locale} />

    <!-- Filter bar card -->
    <div class="filter-card">
      <div class="filter-card__label">📚 学习路径</div>
      <div class="filter-bar" role="group" aria-label="按测试类型筛选">
        <button class="filter-pill filter-pill--active" data-filter="all">全部</button>
        {visibleTestTypes.map((t) => (
          <button class="filter-pill" data-filter={t.id}>
            {t.icon && <span aria-hidden="true">{t.icon}</span>}
            {t.title}
          </button>
        ))}
      </div>
    </div>

    <!-- Test type sections (each is a card block) -->
    {visibleTestTypes.map((testType) => (
      <TestTypeSection testType={testType} locale={locale} />
    ))}

    <!-- Features card -->
    <GuildFeatures locale={locale} />

    <GoogleAd />

    <!-- Workflow card -->
    <LearningWorkflow locale={locale} />

  </div>
</Base>

<script>
  const pills = document.querySelectorAll<HTMLButtonElement>('.filter-pill');
  const sections = document.querySelectorAll<HTMLElement>('[data-testtype]');

  pills.forEach((pill) => {
    pill.addEventListener('click', () => {
      const filter = pill.dataset.filter;
      pills.forEach((p) => p.classList.remove('filter-pill--active'));
      pill.classList.add('filter-pill--active');
      sections.forEach((s) => {
        s.hidden = !(filter === 'all' || s.dataset.testtype === filter);
      });
    });
  });
</script>

<style>
  .guild-page {
    padding-block-start: var(--sp-m);
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  /* ── Filter card ── */
  .filter-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 16px;
    padding: 1.25rem 1.5rem;
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .filter-card__label {
    font-size: 0.8rem;
    font-weight: 700;
    color: color-mix(in srgb, var(--color-main) 55%, transparent);
    white-space: nowrap;
    letter-spacing: 0.03em;
  }

  .filter-bar {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  .filter-pill {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    padding: 0.35rem 0.9rem;
    border-radius: 999px;
    font-size: 0.8rem;
    font-weight: 500;
    cursor: pointer;
    border: 1px solid var(--color-border);
    background: transparent;
    color: color-mix(in srgb, var(--color-main) 75%, transparent);
    transition: border-color 0.15s, background 0.15s, color 0.15s;
  }

  .filter-pill:hover {
    border-color: var(--color-theme);
    color: var(--color-theme);
  }

  .filter-pill--active {
    background: var(--color-theme);
    border-color: var(--color-theme);
    color: #fff;
  }

  .filter-pill--active:hover {
    opacity: 0.9;
    color: #fff;
  }

  @media (max-width: 480px) {
    .filter-card {
      flex-direction: column;
      align-items: flex-start;
    }
  }
</style>
