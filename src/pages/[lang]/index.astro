---
import { LOCALES, useTranslations, type Lang } from "@/i18n";
import Layout from "@/layouts/Base.astro";
import { getRelativeLocaleUrl } from "astro:i18n";
import { getCollection } from "astro:content";
import { marked } from "marked";
import { PROJECTS_LIST } from "@/data/projects";
import {
  SITE_TITLE,
  SITE_SLOGAN,
  HOME_INTRO,
  HOME_INTRO_GREETING,
  HOME_LATEST_POSTS,
  HOME_VIEW_ALL,
  HOME_PROJECTS_TITLE,
  HOME_TAGS_TITLE,
  HOME_VIEW_ALL_PROJECTS,
  HOME_WIKI_SECTION_TITLE,
  HOME_WIKI_INTRO,
  PROMPTS_PAGE_TITLE,
  PROMPTS_WORKFLOWS_SECTION_TITLE,
  HOME_PAGE_DESCRIPTION,
  HOME_PAGE_KEYWORDS,
} from "@/consts";
import { getTitleZhFromBody, getTitleZh, wikiIdToSlug } from "@/data/wiki";
import GuildShowcase from "@/components/guild/GuildShowcase.astro";
import GoogleAd from "@/components/GoogleAd.astro";
import TrackingEvents from "@/components/TrackingEvents.astro";

const locale = Astro.currentLocale as Lang;
const t = useTranslations(locale);

const allPosts = (await getCollection("blog"))
  .filter((post) => post.id.split("/")[0] === locale);

const latestPosts = [...allPosts]
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 6);
const heroLatestPosts = latestPosts.slice(0, 6);

const allWorkflows = await getCollection("workflows");
const tagCounts = allPosts.flatMap((post) => post.data.tags || []).reduce((acc, tag) => {
  acc[tag] = (acc[tag] || 0) + 1;
  return acc;
}, {} as Record<string, number>);

const popularTags = Object.entries(tagCounts)
  .sort(([, a], [, b]) => b - a)
  .slice(0, 30)
  .map(([tag]) => tag);

const featuredProjects = PROJECTS_LIST.slice(0, 4);

// Prompts showcase data
const TESTING_TYPE_ORDER = [
  "requirements-analysis", "test-case-writing", "functional-testing",
  "performance-testing", "automation-testing", "mobile-testing",
  "bug-reporting", "test-reporting", "test-strategy", "ai-assisted-testing",
  "manual-testing", "security-testing", "api-testing", "accessibility-testing", "test-case-reviewer",
];
const allPrompts = await getCollection("prompts");
const localePrompts = allPrompts.filter((p) => p.data.lang === locale);
const promptTypeMap = new Map<string, typeof localePrompts[0]>();
for (const p of localePrompts.sort((a, b) => a.data.order - b.data.order)) {
  if (!promptTypeMap.has(p.data.testingType)) promptTypeMap.set(p.data.testingType, p);
}
const promptTypeCards = Array.from(promptTypeMap.values())
  .sort((a, b) => TESTING_TYPE_ORDER.indexOf(a.data.testingType) - TESTING_TYPE_ORDER.indexOf(b.data.testingType));
const heroPromptCards = shuffle(promptTypeCards).slice(0, 6);

const localeWorkflows = allWorkflows
  .filter((w) => w.data.lang === locale)
  .sort((a, b) => a.data.order - b.data.order)
  .slice(0, 3);
const allGuildEntries = await getCollection("guild");
const localeGuildEntries = allGuildEntries.filter((entry) => entry.id.split("/")[0] === locale);
const heroGuildArticles = shuffle(localeGuildEntries).slice(0, 6);

const wikiEntries =
  locale === "zh-cn"
    ? (await getCollection("wiki")).map((e) => {
        const slug = wikiIdToSlug(e.id);
        const labelZh =
          getTitleZhFromBody(e.body) || getTitleZh(e.data?.title ?? "") || slug;
        return { slug, labelZh };
      })
    : [];
function shuffle<T>(arr: T[]): T[] {
  const a = [...arr];
  for (let i = a.length - 1; i > 0; i--) {
    const j = Math.floor(Math.random() * (i + 1));
    [a[i], a[j]] = [a[j], a[i]];
  }
  return a;
}
const wikiCarouselItems = wikiEntries.length > 0 ? shuffle(wikiEntries).slice(0, 30) : [];
const aiWikiEntries = (await getCollection("aiwiki"))
  .filter((e) => (e.data.lang ?? "en") === locale)
  .map((e) => {
    const slug = e.data.slug ?? e.id.split("/").pop()?.replace(/\.md$/, "") ?? e.id;
    const label = e.data.title || e.data.titleZh || e.data.titleEn || slug;
    const summary = e.data.summary ?? "";
    return { slug, label, summary };
  });
const aiWikiShowcaseItems = shuffle(aiWikiEntries).slice(0, 12);
const heroSummary =
  locale === "zh-cn"
    ? "聚焦 QA、AI、测试工程与专业术语，提供双语博客、AI 百科、测试百科与实战项目入口，帮助你快速进入核心内容。"
    : "Focused on QA, AI, testing engineering, and terminology, with fast entry points to bilingual posts, AI Wiki, QA Wiki, and hands-on projects.";

const introHtmlRaw = marked(t(HOME_INTRO), { gfm: true }) as string;
const wechatQrUrl = "https://cdn.jsdelivr.net/gh/naodeng/blogimg@master/uPic/2023112015%27QR%20Code%20for%20%E5%85%AC%E4%BC%97%E5%8F%B7.jpg";
const wechatTriggerHtml = `<span class="intro-wechat-trigger" tabindex="0" title="${locale === "zh-cn" ? "微信公众号：软件测试同学" : "WeChat: 软件测试同学"}">软件测试同学<span class="intro-wechat-qr"><img src="${wechatQrUrl}" alt="微信公众号 软件测试同学 二维码" width="400" height="400" loading="lazy" /></span></span>`;
const introHtml = introHtmlRaw.replace("<strong>软件测试同学</strong>", wechatTriggerHtml);
export const getStaticPaths = () =>
  Object.keys(LOCALES).map((lang) => ({
    params: { lang },
  }));

const siteOrigin = "https://inaodeng.com";
const homeUrl = `${siteOrigin}/${locale}/`;

// Structured data: CollectionPage for homepage
const homePageSchema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  name: t(SITE_TITLE),
  description: t(HOME_PAGE_DESCRIPTION),
  url: homeUrl,
  inLanguage: locale === "zh-cn" ? "zh-CN" : "en",
  author: {
    "@type": "Person",
    name: "Nao Deng",
    url: siteOrigin,
  },
  publisher: {
    "@type": "Organization",
    name: t(SITE_TITLE),
    url: siteOrigin,
    logo: { "@type": "ImageObject", url: `${siteOrigin}/ogp.png`, width: 1200, height: 630 },
  },
};
---

<Layout
  title={t(SITE_TITLE)}
  description={t(HOME_PAGE_DESCRIPTION)}
  keywords={t(HOME_PAGE_KEYWORDS)}
  extraStructuredData={[homePageSchema]}
>
  <section class="home-hero-switcher" aria-label={locale === "zh-cn" ? "首页模块切换" : "Homepage module switcher"}>
    <div class="hero-switcher-shell" data-hero-switcher>
      <button
        type="button"
        class="hero-switcher-arrow hero-switcher-arrow--prev"
        data-hero-prev
        aria-label={locale === "zh-cn" ? "切换到上一个模块" : "Previous module"}
      >
        <span class="material-icons-sharp" aria-hidden="true">chevron_left</span>
      </button>
      <button
        type="button"
        class="hero-switcher-arrow hero-switcher-arrow--next"
        data-hero-next
        aria-label={locale === "zh-cn" ? "切换到下一个模块" : "Next module"}
      >
        <span class="material-icons-sharp" aria-hidden="true">chevron_right</span>
      </button>
      <div class="hero-switcher-panels">
        <section
          class="hero-switcher-panel is-active"
          id="hero-panel-overview"
          role="tabpanel"
          aria-label={locale === "zh-cn" ? "首页概览" : "Overview"}
          data-hero-panel="overview"
        >
          <div class="intro-section">
            <div class="intro-card-wrap">
              <div class="intro-row">
                <div class="intro-main">
                  <p class="intro-summary">{heroSummary}</p>
                  <div class="intro-card" set:html={introHtml} />
                </div>
                <aside class="intro-sidebar">
                  <div class="intro-sidebar-inner">
                    <div class="intro-logo-wrap">
                      <a href={getRelativeLocaleUrl(locale, "/about")} class="intro-logo-link" title={locale === "zh-cn" ? "关于我" : "About me"}>
                        <img src="/favicon.svg" alt={t(SITE_TITLE)} class="intro-logo" width="140" height="140" />
                      </a>
                    </div>
                    <p class="intro-greeting">{t(HOME_INTRO_GREETING)}</p>
                    <p class="intro-slogan">{t(SITE_SLOGAN)}</p>
                    <nav class="intro-quick-nav" aria-label={locale === "zh-cn" ? "快速入口" : "Quick links"}>
                      <a class="intro-quick-pill tag-pill" href={getRelativeLocaleUrl(locale, "/guild/")}>
                        {locale === "zh-cn" ? "测试指南" : "Testing Guide"}
                      </a>
                      <a class="intro-quick-pill tag-pill" href={getRelativeLocaleUrl(locale, "/prompts/")}>
                        {locale === "zh-cn" ? "测试提示词" : "Testing Prompts"}
                      </a>
                      <a class="intro-quick-pill tag-pill" href={getRelativeLocaleUrl(locale, "/wiki/")}>
                        {locale === "zh-cn" ? "测试百科" : "Testing Wiki"}
                      </a>
                    </nav>
                  </div>
                </aside>
              </div>
            </div>
          </div>
        </section>

        <section
          class="hero-switcher-panel"
          id="hero-panel-playground"
          role="tabpanel"
          aria-label={locale === "zh-cn" ? "最新博客" : "Latest Blog Posts"}
          data-hero-panel="playground"
          hidden
        >
          <div class="hero-feature-card hero-feature-card--highlights">
            <section class="hero-feature-block hero-feature-block--single">
              <h3>{locale === "zh-cn" ? "最新文章" : "Recent Posts"}</h3>
              <div class="hero-feature-list hero-feature-list--single">
                {heroLatestPosts.map((post) => {
                  const [, ...idParts] = post.id.split("/");
                  const postUrl = `/${locale}/blog/${idParts.join("/").toLowerCase()}/`;
                  return (
                    <a href={postUrl} class="hero-feature-item">
                      <strong>{post.data.title}</strong>
                    </a>
                  );
                })}
              </div>
            </section>
          </div>
        </section>

        <section
          class="hero-switcher-panel"
          id="hero-panel-lab"
          role="tabpanel"
          aria-label={locale === "zh-cn" ? "随机提示词" : "Random Prompts"}
          data-hero-panel="lab"
          hidden
        >
          <div class="hero-feature-card hero-feature-card--latest">
            <section class="hero-feature-block hero-feature-block--single">
              <h3>{locale === "zh-cn" ? "提示词" : "Prompts"}</h3>
              <div class="hero-feature-list hero-feature-list--single">
                {heroPromptCards.map((entry) => (
                  <a
                    href={getRelativeLocaleUrl(locale, `/prompts/${entry.data.testingType}/`)}
                    class="hero-feature-item"
                  >
                    <strong>{entry.data.title.replace(/^[^-]+ - /, "")}</strong>
                    <span>{entry.data.description}</span>
                  </a>
                ))}
              </div>
            </section>
          </div>
        </section>

        <section
          class="hero-switcher-panel"
          id="hero-panel-guild"
          role="tabpanel"
          aria-label={locale === "zh-cn" ? "自动化测试指南" : "Automation Testing Guides"}
          data-hero-panel="guild"
          hidden
        >
          <div class="hero-feature-card hero-feature-card--guild">
            <section class="hero-feature-block hero-feature-block--single">
              <h3>{locale === "zh-cn" ? "Guild 文章" : "Guild Articles"}</h3>
              <div class="hero-feature-list hero-feature-list--single">
                {heroGuildArticles.map((entry) => {
                  const [, ...slugParts] = entry.id.split("/");
                  const guildUrl = getRelativeLocaleUrl(locale, `/guild/${slugParts.join("/")}/`);
                  return (
                    <a href={guildUrl} class="hero-feature-item">
                      <strong>{entry.data.title}</strong>
                    </a>
                  );
                })}
              </div>
            </section>
          </div>
        </section>
      </div>
    </div>
  </section>

  <!-- Prompts Showcase -->
  <section class="home-section prompts-showcase">
    <div class="section-header">
      <h2 class="section-title">{t(PROMPTS_PAGE_TITLE)}</h2>
    </div>

    <!-- Testing Types -->
    <p class="prompts-showcase-sub">
      {locale === "zh-cn" ? "测试类型" : "Testing Types"}
    </p>
    <ul class="prompts-type-grid" role="list">
      {promptTypeCards.map((entry) => (
        <li>
          <a
            href={getRelativeLocaleUrl(locale, `/prompts/${entry.data.testingType}/`)}
            class="prompts-type-card"
          >
            <span class="prompts-type-title">{entry.data.title.replace(/^[^-]+ - /, "")}</span>
            <span class="prompts-type-desc">{entry.data.description}</span>
            <span class="prompts-type-cta" aria-hidden="true">
              {locale === "zh-cn" ? "查看 →" : "View →"}
            </span>
          </a>
        </li>
      ))}
    </ul>

    <!-- Workflows -->
    <p class="prompts-showcase-sub" style="margin-block-start: var(--sp-m)">
      {t(PROMPTS_WORKFLOWS_SECTION_TITLE)}
    </p>
    <ul class="prompts-workflow-grid" role="list">
      {localeWorkflows.map((wf) => (
        <li>
          <a
            href={getRelativeLocaleUrl(locale, `/prompts/workflows/${wf.data.workflowType}/`)}
            class="prompts-workflow-card"
          >
            <span class="prompts-type-title">{wf.data.title}</span>
            <span class="prompts-type-desc">{wf.data.description}</span>
            <span class="prompts-type-cta" aria-hidden="true">
              {locale === "zh-cn" ? "查看工作流程 →" : "View workflow →"}
            </span>
          </a>
        </li>
      ))}
    </ul>

    <div class="section-footer">
      <a href={getRelativeLocaleUrl(locale, "/prompts/")} class="cta-button">
        {locale === "zh-cn" ? "查看全部提示词" : "View all prompts"}
        <span class="material-icons-sharp">arrow_forward</span>
      </a>
    </div>
  </section>

  {!import.meta.env.DEV && (
    <div class="home-ad-wrap" aria-hidden="true">
      <ins
        class="adsbygoogle"
        style="display:block; text-align:center;"
        data-ad-layout="in-article"
        data-ad-format="fluid"
        data-ad-client="ca-pub-7249159446737834"
        data-ad-slot="5247439587"
      />
      <script is:inline>(adsbygoogle = window.adsbygoogle || []).push({});</script>
    </div>
  )}

  <section class="home-section projects-showcase">
    <div class="section-header">
      <h2 class="section-title">{t(HOME_PROJECTS_TITLE)}</h2>
    </div>
    <div class="project-grid">
      {featuredProjects.map((proj) => (
        <a href={proj.url} target="_blank" rel="noopener noreferrer" class="project-card">
          <div class="project-content">
            <h3 class="project-name">{t(proj.name)}</h3>
            <div class="project-tech-tags">
              {t(proj.techStack).split(/[、,，]/).map((tech) => (
                <span class="mini-tag">{tech.trim()}</span>
              ))}
            </div>
            <p class="project-desc">{t(proj.description)}</p>
          </div>
          <div class="project-footer">
            <span class="external-icon">
              <span class="material-icons-sharp">open_in_new</span>
            </span>
          </div>
        </a>
      ))}
    </div>
    <div class="section-footer">
      <a href={getRelativeLocaleUrl(locale, "/projects")} class="cta-button">
        {t(HOME_VIEW_ALL_PROJECTS)}
        <span class="material-icons-sharp">arrow_forward</span>
      </a>
    </div>
  </section>

  <GuildShowcase locale={locale} />

  {locale === "zh-cn" && wikiCarouselItems.length > 0 && (
    <section class="home-section wiki-showcase" aria-labelledby="wiki-showcase-title">
      <div class="section-header">
        <h2 id="wiki-showcase-title" class="section-title">{HOME_WIKI_SECTION_TITLE}</h2>
      </div>
      <p class="wiki-intro">{HOME_WIKI_INTRO}</p>
      <div class="wiki-carousel-viewport">
        <div class="wiki-carousel-track">
          {[...wikiCarouselItems, ...wikiCarouselItems].map((item) => (
            <a
              href={getRelativeLocaleUrl("zh-cn", `/wiki/${item.slug}`)}
              class="wiki-term-item"
              title={item.labelZh}
            >
              <span class="wiki-term-text">{item.labelZh}</span>
            </a>
          ))}
        </div>
      </div>
      <div class="section-footer">
        <a href={getRelativeLocaleUrl(locale, "/wiki")} class="cta-button secondary">
          {locale === "zh-cn" ? "进入百科" : "QA Wiki"}
          <span class="material-icons-sharp">menu_book</span>
        </a>
      </div>
    </section>
  )}

  <section class="home-section tags-cloud">
    <div class="section-header">
      <h2 class="section-title">{t(HOME_TAGS_TITLE)}</h2>
    </div>
    <div class="tags-container">
      {popularTags.map((tag) => (
        <a href={getRelativeLocaleUrl(locale, `/tags/${tag.includes("/") || tag.includes(" ") ? encodeURIComponent(tag) : tag}`)} class="tag-pill">
          <span class="tag-hash">#</span>{tag}
          <span class="tag-count">{tagCounts[tag]}</span>
        </a>
      ))}
    </div>
  </section>

  <GoogleAd />

  <section class="home-section latest">
    <div class="section-header">
      <h2 class="section-title">{t(HOME_LATEST_POSTS)}</h2>
    </div>
    <div class="post-grid">
      {latestPosts.map((post) => {
        const [, ...idParts] = post.id.split("/");
        const postUrl = `/${locale}/blog/${idParts.join("/").toLowerCase()}/`;
        const dateStr = post.data.date.toLocaleDateString(
          locale === "zh-cn" ? "zh-CN" : "en-US",
          { year: "numeric", month: "short", day: "numeric" }
        );
        // Estimate reading time from description length (avg 5 chars/word for zh, 5 chars/word for en)
        const descWords = post.data.description ? Math.ceil(post.data.description.length / 5) : 0;
        const estimatedWords = descWords > 0 ? descWords * 10 : 300;
        const readMins = Math.max(1, Math.ceil(estimatedWords / 200));
        const readLabel = locale === "zh-cn" ? `${readMins} 分钟阅读` : `${readMins} min read`;
        return (
          <article class="post-card">
            <a href={postUrl} class="post-card-link">
              <div class="post-content">
                <time class="post-date">{dateStr}</time>
                <h3 class="post-title">{post.data.title}</h3>
                <p class="post-excerpt">{post.data.description}</p>
              </div>
            </a>
            <div class="post-footer">
              <span class="post-reading-time">{readLabel}</span>
              {post.data.tags && post.data.tags.length > 0 && (
                <div class="post-tags">
                  {post.data.tags.slice(0, 2).map((tag) => (
                    <a href={`/${locale}/tags/${tag.includes("/") || tag.includes(" ") ? encodeURIComponent(tag) : tag}/`} class="tag-link">
                      #{tag}
                    </a>
                  ))}
                </div>
              )}
            </div>
          </article>
        );
      })}
    </div>
    <div class="section-footer">
      <a href={getRelativeLocaleUrl(locale, "/blog")} class="cta-button secondary">
        {t(HOME_VIEW_ALL)}
        <span class="material-icons-sharp">arrow_right_alt</span>
      </a>
    </div>
  </section>

  <section class="home-section aiwiki-showcase" aria-labelledby="aiwiki-showcase-title">
    <div class="section-header">
      <h2 id="aiwiki-showcase-title" class="section-title">
        {locale === "zh-cn" ? "AI 百科" : "AI Wiki"}
      </h2>
    </div>
    <p class="wiki-intro">
      {locale === "zh-cn"
        ? "精选 AI 与 Vibe Coding 词条，覆盖模型、Agent、上下文、规则与工程实践。"
        : "Selected AI and vibe-coding terms across models, agents, context, rules, and engineering practices."}
    </p>
    <div class="wiki-carousel-viewport">
      <div class="wiki-carousel-track">
        {[...aiWikiShowcaseItems, ...aiWikiShowcaseItems].map((item) => (
          <a
            href={getRelativeLocaleUrl(locale, `/AIWiki/${item.slug}/`)}
            class="wiki-term-item"
            title={item.label}
          >
            <span class="wiki-term-text">{item.label}</span>
          </a>
        ))}
      </div>
    </div>
    <div class="section-footer">
      <a href={getRelativeLocaleUrl(locale, "/AIWiki")} class="cta-button secondary">
        {locale === "zh-cn" ? "进入 AI 百科" : "View AI Wiki"}
        <span class="material-icons-sharp">menu_book</span>
      </a>
    </div>
  </section>
</Layout>

<TrackingEvents mode="home" locale={locale} />

<script is:inline>
  const initHeroSwitcher = () => {
    const root = document.querySelector("[data-hero-switcher]");
    if (!(root instanceof HTMLElement)) return;

    const tabs = Array.from(root.querySelectorAll("[data-hero-tab]"));
    const panels = Array.from(root.querySelectorAll("[data-hero-panel]"));
    const prevButton = root.querySelector("[data-hero-prev]");
    const nextButton = root.querySelector("[data-hero-next]");
    if (panels.length === 0) return;
    const progressBar = root.querySelector("[data-hero-progress]");
    const overviewPanel = panels.find((panel) => panel.getAttribute("data-hero-panel") === "overview");
    const overviewCard = overviewPanel?.querySelector(".intro-card-wrap");
    const panelIds = panels
      .map((panel) => panel.getAttribute("data-hero-panel"))
      .filter((id) => Boolean(id));
    if (panelIds.length === 0) return;

    const AUTOPLAY_MS = 6500;
    let activeIndex = 0;
    let elapsed = 0;
    let isPaused = false;
    let rafId = 0;
    let lastTime = performance.now();

    const setProgress = (ratio) => {
      if (!(progressBar instanceof HTMLElement)) return;
      const safeRatio = Math.max(0, Math.min(1, ratio));
      progressBar.style.transform = `scaleX(${safeRatio})`;
    };

    const syncPanelHeightToOverview = () => {
      if (!(overviewPanel instanceof HTMLElement) || !(overviewCard instanceof HTMLElement)) return;

      const wasHidden = overviewPanel.hasAttribute("hidden");
      const previousStyle = overviewPanel.getAttribute("style");

      if (wasHidden) {
        overviewPanel.hidden = false;
        overviewPanel.style.position = "absolute";
        overviewPanel.style.visibility = "hidden";
        overviewPanel.style.pointerEvents = "none";
        overviewPanel.style.inset = "0";
      }

    const measuredHeight = Math.ceil(overviewCard.scrollHeight);
      if (measuredHeight > 0) root.style.setProperty("--hero-panel-height", `${measuredHeight}px`);

      if (wasHidden) {
        if (previousStyle === null) {
          overviewPanel.removeAttribute("style");
        } else {
          overviewPanel.setAttribute("style", previousStyle);
        }
        overviewPanel.hidden = true;
      }
    };

    const activate = (targetId, shouldResetProgress = false) => {
      tabs.forEach((tab) => {
        const isActive = tab.getAttribute("data-hero-tab") === targetId;
        tab.classList.toggle("is-active", isActive);
        tab.setAttribute("aria-selected", isActive ? "true" : "false");
      });

      panels.forEach((panel) => {
        const isActive = panel.getAttribute("data-hero-panel") === targetId;
        panel.classList.toggle("is-active", isActive);
        panel.toggleAttribute("hidden", !isActive);
      });

      const foundIndex = panelIds.findIndex((id) => id === targetId);
      if (foundIndex >= 0) activeIndex = foundIndex;
      if (shouldResetProgress) {
        elapsed = 0;
        setProgress(0);
      }
    };

    const activateRelative = (delta) => {
      const nextIndex = (activeIndex + delta + panelIds.length) % panelIds.length;
      const targetId = panelIds[nextIndex];
      if (targetId) activate(targetId, true);
    };

    const step = (now) => {
      const delta = now - lastTime;
      lastTime = now;

      if (!isPaused) {
        elapsed += delta;
        if (elapsed >= AUTOPLAY_MS) {
          const nextIndex = (activeIndex + 1) % panelIds.length;
          const targetId = panelIds[nextIndex];
          if (targetId) activate(targetId, true);
        } else {
          setProgress(elapsed / AUTOPLAY_MS);
        }
      }

      rafId = requestAnimationFrame(step);
    };

    const setPaused = (paused) => {
      if (isPaused === paused) return;
      isPaused = paused;
      lastTime = performance.now();
    };

    tabs.forEach((tab, index) => {
      tab.addEventListener("click", () => {
        const targetId = tab.getAttribute("data-hero-tab");
        if (targetId) activate(targetId, true);
      });

      tab.addEventListener("keydown", (event) => {
        if (!(event instanceof KeyboardEvent)) return;
        if (event.key !== "ArrowRight" && event.key !== "ArrowLeft") return;

        event.preventDefault();
        const delta = event.key === "ArrowRight" ? 1 : -1;
        const nextIndex = (index + delta + tabs.length) % tabs.length;
        const nextTab = tabs[nextIndex];
        const targetId = nextTab?.getAttribute("data-hero-tab");
        if (targetId) activate(targetId, true);
        if (nextTab instanceof HTMLElement) nextTab.focus();
      });
    });

    if (prevButton instanceof HTMLElement) {
      prevButton.addEventListener("click", () => {
        activateRelative(-1);
        prevButton.blur();
      });
    }
    if (nextButton instanceof HTMLElement) {
      nextButton.addEventListener("click", () => {
        activateRelative(1);
        nextButton.blur();
      });
    }

    root.addEventListener("mouseenter", () => setPaused(true));
    root.addEventListener("mouseleave", () => setPaused(false));
    root.addEventListener("focusin", () => setPaused(true));
    root.addEventListener("focusout", () => {
      const active = document.activeElement;
      if (!active || !root.contains(active)) setPaused(false);
    });
    document.addEventListener("visibilitychange", () => {
      setPaused(document.hidden);
    });

    let resizeRaf = 0;
    const onResize = () => {
      if (resizeRaf) cancelAnimationFrame(resizeRaf);
      resizeRaf = requestAnimationFrame(syncPanelHeightToOverview);
    };
    window.addEventListener("resize", onResize, { passive: true });

    syncPanelHeightToOverview();
    setProgress(0);
    rafId = requestAnimationFrame(step);
    window.addEventListener(
      "pagehide",
      () => {
        cancelAnimationFrame(rafId);
        if (resizeRaf) cancelAnimationFrame(resizeRaf);
        window.removeEventListener("resize", onResize);
      },
      { once: true }
    );
  };

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initHeroSwitcher, { once: true });
  } else {
    initHeroSwitcher();
  }
</script>

