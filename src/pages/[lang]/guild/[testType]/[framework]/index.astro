---
/**
 * Guild 框架概述页
 * 路由格式: /[lang]/guild/[testType]/[framework]/
 */
import { getCollection } from "astro:content";
import Base from "@/layouts/Base.astro";
import Breadcrumb from "@/components/Breadcrumb.astro";
import { NAV_HOME, NAV_GUILD } from "@/consts";
import { getGuildConfig, learningStages } from "@/config/guild.config";
import { filterGuildEntries, guildIdToSlug, getDifficultyName } from "@/data/guild";
import FrameworkWorkflow from "@/components/guild/FrameworkWorkflow.astro";
import type { Lang } from "@/i18n";
import type { GuildEntry } from "@/data/guild";

export async function getStaticPaths() {
  const paths: Array<{ params: { lang: string; testType: string; framework: string } }> = [];
  
  // 为每个 locale 的每个框架生成路径
  const locales = ["zh-cn", "en"];
  
  for (const locale of locales) {
    const config = getGuildConfig(locale as Lang);
    
    for (const testType of config.testTypes) {
      for (const framework of testType.frameworks) {
        paths.push({
          params: {
            lang: locale,
            testType: testType.id,
            framework: framework.id,
          },
        });
      }
    }
  }
  
  return paths;
}

const { lang, testType, framework } = Astro.params;
const locale = (lang ?? "zh-cn") as Lang;

const config = getGuildConfig(locale);
const testTypeConfig = config.testTypes.find((t) => t.id === testType);
const frameworkConfig = testTypeConfig?.frameworks.find((f) => f.id === framework);

if (!testTypeConfig || !frameworkConfig) {
  return Astro.redirect(`/${locale}/guild/`);
}

// 获取该框架的所有文章
const allEntries = await getCollection("guild");
const frameworkEntries = filterGuildEntries(allEntries, locale, testType, framework);

// 按 stage 分组
const stages = learningStages[locale as keyof typeof learningStages];
const stageOrder = ["getting-started", "basic", "advanced", "ci-cd", "best-practices"];
const byStage = new Map<string, GuildEntry[]>();

frameworkEntries.forEach((entry) => {
  const stage = entry.data.stage || "getting-started";
  const list = byStage.get(stage) || [];
  list.push(entry);
  byStage.set(stage, list);
});

// 排序每个 stage 的文章
byStage.forEach((list) => {
  list.sort((a, b) => (a.data.order || 999) - (b.data.order || 999));
});

// 面包屑
const homeName = (typeof NAV_HOME === "string" ? NAV_HOME : NAV_HOME[locale]) ?? (locale === "zh-cn" ? "首页" : "Home");
const guildName = (typeof NAV_GUILD === "string" ? NAV_GUILD : NAV_GUILD[locale]) ?? "Guild";

const breadcrumbs = [
  { name: homeName, url: `/${locale}/` },
  { name: guildName, url: `/${locale}/guild/` },
  { name: testTypeConfig.title, url: `/${locale}/guild/#${testType}` },
  { name: frameworkConfig.name, url: `/${locale}/guild/${testType}/${framework}/` },
];

const pageTitle = `${frameworkConfig.name} ${locale === "zh-cn" ? "教程" : "Tutorial"}`;
const metaDescription = frameworkConfig.description;

// 生成丰富的介绍文案（100字以内）
const diffLabel = locale === "zh-cn"
  ? { beginner: "初级", intermediate: "中级", advanced: "高级" }[frameworkConfig.difficulty ?? "beginner"] ?? ""
  : { beginner: "beginner-friendly", intermediate: "intermediate", advanced: "advanced" }[frameworkConfig.difficulty ?? "beginner"] ?? "";

const richDesc = locale === "zh-cn"
  ? `${frameworkConfig.description}。本专区提供 ${frameworkEntries.length} 篇系统化教程，覆盖从环境搭建到 CI/CD 集成的完整学习路径，适合${diffLabel}开发者和测试工程师快速上手 ${testTypeConfig.title}。`
  : `${frameworkConfig.description}. This section offers ${frameworkEntries.length} structured tutorials covering environment setup through CI/CD integration — a complete ${diffLabel} learning path for ${testTypeConfig.title}.`;
---

<Base title={pageTitle} description={metaDescription} contentWide={true}>
  <Breadcrumb items={breadcrumbs} />
  
  <div class="framework-overview">
    <!-- 框架头部 -->
    <header class="fw-hero">
      <div class="fw-hero__left">
        {frameworkConfig.icon && (
          <img src={frameworkConfig.icon} alt={frameworkConfig.name} class="fw-hero__icon" width="56" height="56" loading="eager" />
        )}
        <div class="fw-hero__info">
          <div class="fw-hero__badges">
            <span class="fw-badge fw-badge--type">{testTypeConfig.icon} {testTypeConfig.title}</span>
            {frameworkConfig.difficulty && (
              <span class={`fw-badge fw-badge--diff fw-badge--${frameworkConfig.difficulty}`}>
                {locale === "zh-cn"
                  ? { beginner: "初级", intermediate: "中级", advanced: "高级" }[frameworkConfig.difficulty]
                  : { beginner: "Beginner", intermediate: "Intermediate", advanced: "Advanced" }[frameworkConfig.difficulty]
                }
              </span>
            )}
          </div>
          <h1 class="fw-hero__title">{frameworkConfig.name}</h1>
          <p class="fw-hero__desc">{richDesc}</p>
        </div>
      </div>

      <div class="fw-hero__row2">
        <div class="fw-hero__stats">
          <div class="fw-stat">
            <span class="fw-stat__value">{frameworkEntries.length}</span>
            <span class="fw-stat__label">{locale === "zh-cn" ? "篇教程" : "Articles"}</span>
          </div>
          <div class="fw-stat-sep"></div>
          <div class="fw-stat">
            <span class="fw-stat__value">{frameworkConfig.language}</span>
            <span class="fw-stat__label">{locale === "zh-cn" ? "编程语言" : "Language"}</span>
          </div>
          <div class="fw-stat-sep"></div>
          <div class="fw-stat">
            <span class="fw-stat__value">{byStage.size}</span>
            <span class="fw-stat__label">{locale === "zh-cn" ? "学习阶段" : "Stages"}</span>
          </div>
        </div>

        <div class="fw-hero__links">
          <a href="#learning-path" class="fw-link fw-link--start">
            {locale === "zh-cn" ? "立即开始 →" : "Start Learning →"}
          </a>
          {frameworkConfig.githubDemo && (
            <a href={frameworkConfig.githubDemo} target="_blank" rel="noopener noreferrer" class="fw-link fw-link--primary">
              <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
              </svg>
              {locale === "zh-cn" ? "示例代码" : "Demo Code"}
            </a>
          )}
          {frameworkConfig.officialDocs && (
            <a href={frameworkConfig.officialDocs} target="_blank" rel="noopener noreferrer" class="fw-link fw-link--ghost">
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/>
              </svg>
              {locale === "zh-cn" ? "官方文档" : "Official Docs"}
            </a>
          )}
        </div>
      </div>
    </header>

    <!-- 学习工作流程 -->
    <FrameworkWorkflow
      framework={frameworkConfig}
      testType={testTypeConfig}
      locale={locale}
      articleCount={frameworkEntries.length}
    />

    <!-- 学习路径 -->
    <div class="learning-path" id="learning-path">
      <div class="lp-header">
        <div class="lp-header__left">
          <h2 class="learning-path-title">
            {locale === "zh-cn" ? "📖 学习路径" : "📖 Learning Path"}
          </h2>
          <span class="lp-count">{frameworkEntries.length} {locale === "zh-cn" ? "篇" : "articles"}</span>
        </div>
        <div class="lp-filters" role="group" aria-label={locale === "zh-cn" ? "按阶段筛选" : "Filter by stage"}>
          <button class="lp-pill lp-pill--active" data-stage="all">
            {locale === "zh-cn" ? "全部" : "All"}
          </button>
          {stageOrder.filter(s => byStage.has(s)).map((stageKey) => (
            <button class="lp-pill" data-stage={stageKey}>
              {stages[stageKey as keyof typeof stages] || stageKey}
            </button>
          ))}
        </div>
      </div>

      {stageOrder.map((stageKey) => {
        const stageEntries = byStage.get(stageKey);
        if (!stageEntries || stageEntries.length === 0) return null;
        
        const stageName = stages[stageKey as keyof typeof stages] || stageKey;
        
        return (
          <section class="stage-section" data-stage={stageKey}>
            <h3 class="stage-title">{stageName}</h3>
            <div class="articles-grid">
              {stageEntries.map((entry) => {
                const slug = guildIdToSlug(entry.id);
                const difficultyName = getDifficultyName(entry.data.difficulty, locale);
                
                return (
                  <a href={`/${locale}/guild/${slug}/`} class="article-card">
                    <h4 class="article-title">{entry.data.title}</h4>
                    {entry.data.description && (
                      <p class="article-description">{entry.data.description}</p>
                    )}
                    <div class="article-meta">
                      <span class="article-meta-item">
                        <svg xmlns="http://www.w3.org/2000/svg" width="1em" height="1em" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                          <circle cx="12" cy="12" r="10"/>
                          <polyline points="12 6 12 12 16 14"/>
                        </svg>
                        {entry.data.duration ? `${entry.data.duration} ${locale === "zh-cn" ? "分钟" : "min"}` : "-"}
                      </span>
                      <span class="article-meta-item article-difficulty" data-difficulty={entry.data.difficulty}>
                        {difficultyName}
                      </span>
                    </div>
                  </a>
                );
              })}
            </div>
          </section>
        );
      })}
    </div>

  </div>
</Base>

<script>
  const pills = document.querySelectorAll<HTMLButtonElement>('.lp-pill');
  const sections = document.querySelectorAll<HTMLElement>('.stage-section');

  pills.forEach((pill) => {
    pill.addEventListener('click', () => {
      const stage = pill.dataset.stage;
      pills.forEach((p) => p.classList.remove('lp-pill--active'));
      pill.classList.add('lp-pill--active');
      sections.forEach((s) => {
        s.hidden = !(stage === 'all' || s.dataset.stage === stage);
      });
    });
  });
</script>

<style>
  .framework-overview {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 var(--sp-m) var(--sp-xl);
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  /* ── Hero header ── */
  .fw-hero {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 16px;
    padding: 1.75rem;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    position: relative;
    overflow: hidden;
  }

  .fw-hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse 60% 40% at 0% 0%, color-mix(in srgb, var(--color-theme) 6%, transparent), transparent 70%);
    pointer-events: none;
  }

  .fw-hero__left {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
    position: relative;
  }

  .fw-hero__icon {
    width: 56px;
    height: 56px;
    object-fit: contain;
    border-radius: 12px;
    flex-shrink: 0;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    padding: 6px;
  }

  .fw-hero__info {
    flex: 1;
    min-width: 0;
  }

  .fw-hero__badges {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-bottom: 0.6rem;
  }

  .fw-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    padding: 0.2em 0.7em;
    border-radius: 999px;
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.02em;
  }

  .fw-badge--type {
    color: var(--color-theme);
    background: color-mix(in srgb, var(--color-theme) 10%, transparent);
    border: 1px solid color-mix(in srgb, var(--color-theme) 20%, transparent);
  }

  .fw-badge--diff {
    border: 1px solid transparent;
  }

  .fw-badge--beginner  { background: rgba(16,185,129,.12); color: #10b981; border-color: rgba(16,185,129,.2); }
  .fw-badge--intermediate { background: rgba(245,158,11,.12); color: #f59e0b; border-color: rgba(245,158,11,.2); }
  .fw-badge--advanced  { background: rgba(239,68,68,.12);  color: #ef4444; border-color: rgba(239,68,68,.2); }

  .fw-hero__title {
    font-size: clamp(1.5rem, 3vw, 2.25rem);
    font-weight: 900;
    letter-spacing: -0.02em;
    color: var(--color-main);
    margin: 0 0 0.5rem;
    line-height: 1.2;
  }

  .fw-hero__desc {
    font-size: 0.95rem;
    line-height: 1.65;
    color: color-mix(in srgb, var(--color-main) 68%, transparent);
    margin: 0;
  }

  /* Stats + links row */
  .fw-hero__row2 {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding-top: 1rem;
    border-top: 1px solid var(--color-border);
    flex-wrap: wrap;
    position: relative;
  }

  .fw-hero__stats {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    flex-wrap: wrap;
  }

  .fw-stat {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }

  .fw-stat__value {
    font-size: 1.1rem;
    font-weight: 800;
    color: var(--color-theme);
    line-height: 1;
    font-family: var(--english-font);
  }

  .fw-stat__label {
    font-size: 0.7rem;
    color: color-mix(in srgb, var(--color-main) 55%, transparent);
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .fw-stat-sep {
    width: 1px;
    height: 2rem;
    background: var(--color-border);
    flex-shrink: 0;
  }

  /* Links */
  .fw-hero__links {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .fw-link {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    padding: 0.55em 1.1em;
    border-radius: 8px;
    font-size: 0.85rem;
    font-weight: 600;
    text-decoration: none;
    transition: var(--transition-base);
  }

  .fw-link--start {
    background: var(--color-theme);
    color: #fff;
    border: 1px solid var(--color-theme);
    font-size: 0.9rem;
  }

  .fw-link--start:hover {
    opacity: 0.88;
    transform: translateY(-2px);
    box-shadow: 0 0 16px var(--glow-theme);
  }

  .fw-link--primary {
    background: transparent;
    color: var(--color-theme);
    border: 1px solid color-mix(in srgb, var(--color-theme) 30%, transparent);
  }

  .fw-link--primary:hover {
    background: color-mix(in srgb, var(--color-theme) 8%, transparent);
    border-color: var(--color-theme);
    transform: translateY(-2px);
  }

  .fw-link--ghost {
    background: transparent;
    color: var(--color-theme);
    border: 1px solid color-mix(in srgb, var(--color-theme) 30%, transparent);
  }

  .fw-link--ghost:hover {
    background: color-mix(in srgb, var(--color-theme) 8%, transparent);
    border-color: var(--color-theme);
    transform: translateY(-2px);
  }

  /* ── Learning path ── */
  .learning-path {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .lp-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 12px;
    padding: 1rem 1.25rem;
  }

  .lp-header__left {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .learning-path-title {
    font-size: 1rem;
    font-weight: 800;
    color: var(--color-main);
    margin: 0;
    background: linear-gradient(135deg, var(--color-main) 20%, var(--color-theme));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .lp-count {
    font-size: 0.72rem;
    font-weight: 600;
    color: var(--color-theme);
    background: color-mix(in srgb, var(--color-theme) 10%, transparent);
    border: 1px solid color-mix(in srgb, var(--color-theme) 20%, transparent);
    padding: 0.15em 0.6em;
    border-radius: 999px;
  }

  .lp-filters {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
  }

  .lp-pill {
    display: inline-flex;
    align-items: center;
    padding: 0.3em 0.8em;
    border-radius: 999px;
    font-size: 0.75rem;
    font-weight: 500;
    cursor: pointer;
    border: 1px solid var(--color-border);
    background: transparent;
    color: color-mix(in srgb, var(--color-main) 70%, transparent);
    transition: var(--transition-base);
  }

  .lp-pill:hover {
    border-color: var(--color-theme);
    color: var(--color-theme);
  }

  .lp-pill--active {
    background: var(--color-theme);
    border-color: var(--color-theme);
    color: #fff;
  }

  .lp-pill--active:hover {
    opacity: 0.9;
    color: #fff;
  }

  .stage-section {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .stage-title {
    font-size: 0.85rem;
    font-weight: 700;
    color: var(--color-theme);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin: 0;
    padding-left: 0.75rem;
    border-left: 3px solid var(--color-theme);
  }

  .articles-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 0.75rem;
  }

  .article-card {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    padding: 1rem 1.1rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 12px;
    text-decoration: none;
    transition: var(--transition-base);
  }

  .article-card:hover {
    border-color: var(--color-theme);
    transform: translateY(-4px);
    box-shadow: 0 0 20px var(--glow-theme);
  }

  .article-title {
    font-size: 0.92rem;
    font-weight: 600;
    color: var(--color-main);
    margin: 0;
    line-height: 1.4;
  }

  .article-card:hover .article-title {
    color: var(--color-theme);
  }

  .article-description {
    font-size: 0.8rem;
    line-height: 1.5;
    color: color-mix(in srgb, var(--color-main) 60%, transparent);
    margin: 0;
    flex-grow: 1;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .article-meta {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 0.5rem;
    margin-top: 0.35rem;
    padding-top: 0.5rem;
    border-top: 1px solid var(--color-border);
  }

  .article-meta-item {
    display: flex;
    align-items: center;
    gap: 0.35em;
    font-size: 0.75rem;
    color: color-mix(in srgb, var(--color-main) 55%, transparent);
  }

  .article-difficulty {
    padding: 0.18em 0.6em;
    border-radius: 5px;
    font-weight: 600;
    font-size: 0.72rem;
  }

  .article-difficulty[data-difficulty="beginner"]    { background: rgba(16,185,129,.12); color: #10b981; }
  .article-difficulty[data-difficulty="intermediate"] { background: rgba(245,158,11,.12); color: #f59e0b; }
  .article-difficulty[data-difficulty="advanced"]    { background: rgba(239,68,68,.12);  color: #ef4444; }

  @media (max-width: 600px) {
    .fw-hero { padding: 1.25rem; }
    .fw-hero__icon { width: 44px; height: 44px; }
    .fw-stat-sep { display: none; }
    .articles-grid { grid-template-columns: 1fr; }
  }
</style>
