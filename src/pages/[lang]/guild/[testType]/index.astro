---
/**
 * Guild 测试类型概述页
 * 路由格式: /[lang]/guild/[testType]/
 */
import { getCollection } from "astro:content";
import Base from "@/layouts/Base.astro";
import Breadcrumb from "@/components/Breadcrumb.astro";
import { NAV_HOME, NAV_GUILD } from "@/consts";
import { getGuildConfig } from "@/config/guild.config";
import type { Lang } from "@/i18n";

export async function getStaticPaths() {
  const locales = ["zh-cn", "en"];
  const paths: Array<{ params: { lang: string; testType: string } }> = [];

  for (const locale of locales) {
    const config = getGuildConfig(locale as Lang);
    for (const testType of config.testTypes) {
      paths.push({ params: { lang: locale, testType: testType.id } });
    }
  }

  return paths;
}

const { lang, testType } = Astro.params;
const locale = (lang ?? "zh-cn") as Lang;

const config = getGuildConfig(locale);
const testTypeConfig = config.testTypes.find((t) => t.id === testType);

if (!testTypeConfig) {
  return Astro.redirect(`/${locale}/guild/`);
}

// Article counts per framework
const allEntries = await getCollection("guild");
const articleCountMap: Record<string, number> = {};
for (const fw of testTypeConfig.frameworks) {
  articleCountMap[fw.id] = allEntries.filter(
    (e) => e.data.framework === fw.id && e.data.testType === testType
  ).length;
}

const isZh = locale === "zh-cn";

const homeName = (typeof NAV_HOME === "string" ? NAV_HOME : NAV_HOME[locale]) ?? (isZh ? "首页" : "Home");
const guildName = (typeof NAV_GUILD === "string" ? NAV_GUILD : NAV_GUILD[locale]) ?? "Guild";

const breadcrumbs = [
  { name: homeName, url: `/${locale}/` },
  { name: guildName, url: `/${locale}/guild/` },
  { name: testTypeConfig.title, url: `/${locale}/guild/${testType}/` },
];

const pageTitle = testTypeConfig.title;
const metaDescription = testTypeConfig.description;
---

<Base title={pageTitle} description={metaDescription}>
  <Breadcrumb items={breadcrumbs} />

  <div class="tt-page">
    <!-- Header -->
    <header class="tt-header">
      <span class="tt-header__icon" aria-hidden="true">{testTypeConfig.icon}</span>
      <div>
        <h1 class="tt-header__title">{testTypeConfig.title}</h1>
        <p class="tt-header__desc">{testTypeConfig.description}</p>
      </div>
    </header>

    <!-- Framework grid -->
    <h2 class="tt-section-title">
      {isZh ? "选择框架" : "Choose a Framework"}
    </h2>
    <div class="tt-grid">
      {testTypeConfig.frameworks.map((fw) => {
        const count = articleCountMap[fw.id] ?? 0;
        return (
          <a
            href={`/${locale}/guild/${testType}/${fw.id}/`}
            class="fw-card"
            style={`--fw-color: ${fw.color ?? 'var(--color-theme)'}`}
          >
            <div class="fw-card__top">
              {fw.icon ? (
                <img src={fw.icon} alt={fw.name} class="fw-card__icon" width="32" height="32" loading="lazy" />
              ) : (
                <span class="fw-card__icon-fb" aria-hidden="true">{testTypeConfig.icon}</span>
              )}
              <span class="fw-card__lang">{fw.language}</span>
            </div>
            <span class="fw-card__name">{fw.name}</span>
            <p class="fw-card__desc">{fw.description}</p>
            <div class="fw-card__footer">
              {count > 0 && (
                <span class="fw-card__count">{count} {isZh ? "篇" : "articles"}</span>
              )}
              <span class="fw-card__arrow" aria-hidden="true">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>
                </svg>
              </span>
            </div>
          </a>
        );
      })}
    </div>
  </div>
</Base>

<style>
  .tt-page {
    max-width: 900px;
    margin: 0 auto;
    padding: 0 var(--sp-m) var(--sp-xl);
  }

  .tt-header {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
    margin: 1.5rem 0 2rem;
    padding: 1.5rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 16px;
  }

  .tt-header__icon {
    font-size: 2.5rem;
    line-height: 1;
    flex-shrink: 0;
  }

  .tt-header__title {
    font-size: clamp(1.5rem, 3vw, 2rem);
    font-weight: 800;
    color: var(--color-main);
    margin: 0 0 0.4rem;
  }

  .tt-header__desc {
    font-size: 0.95rem;
    color: color-mix(in srgb, var(--color-main) 65%, transparent);
    margin: 0;
    line-height: 1.6;
  }

  .tt-section-title {
    font-size: 1rem;
    font-weight: 700;
    color: color-mix(in srgb, var(--color-main) 60%, transparent);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin: 0 0 1rem;
  }

  .tt-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: 1rem;
  }

  .fw-card {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    padding: 1.25rem;
    border-radius: 12px;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    text-decoration: none;
    color: inherit;
    position: relative;
    overflow: hidden;
    transition: var(--transition-base);
  }

  .fw-card::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 3px;
    background: var(--fw-color, var(--color-theme));
    opacity: 0;
    transition: var(--transition-base);
  }

  .fw-card:hover {
    border-color: var(--color-theme);
    transform: translateY(-4px);
    box-shadow: 0 0 20px var(--glow-theme);
  }

  .fw-card:hover::before {
    opacity: 1;
  }

  .fw-card__top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
    margin-bottom: 0.25rem;
  }

  .fw-card__icon {
    width: 32px;
    height: 32px;
    object-fit: contain;
    border-radius: 6px;
  }

  .fw-card__icon-fb {
    font-size: 1.5rem;
    line-height: 1;
  }

  .fw-card__lang {
    font-size: 0.68rem;
    font-weight: 600;
    color: color-mix(in srgb, var(--color-main) 50%, transparent);
    background: color-mix(in srgb, var(--color-main) 8%, transparent);
    padding: 0.15em 0.5em;
    border-radius: 4px;
    white-space: nowrap;
  }

  .fw-card__name {
    font-size: 1rem;
    font-weight: 700;
    color: var(--color-main);
    line-height: 1.3;
  }

  .fw-card__desc {
    font-size: 0.82rem;
    color: color-mix(in srgb, var(--color-main) 55%, transparent);
    line-height: 1.5;
    margin: 0;
    flex: 1;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .fw-card__footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-top: 0.5rem;
  }

  .fw-card__count {
    font-size: 0.72rem;
    color: color-mix(in srgb, var(--color-main) 45%, transparent);
  }

  .fw-card__arrow {
    color: var(--color-theme);
    opacity: 0;
    transition: var(--transition-base);
    display: inline-flex;
  }

  .fw-card:hover .fw-card__arrow {
    opacity: 1;
    transform: translateX(3px);
  }

  @media (max-width: 480px) {
    .tt-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>
