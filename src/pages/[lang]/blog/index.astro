---
import { LOCALES, useTranslations, type Lang } from "@/i18n";
import Layout from "@/layouts/Base.astro";
import { getRelativeLocaleUrl } from "astro:i18n";
import { getCollection } from "astro:content";
import PageHeadline from "@/components/PageHeadline.astro";
import PaginationNav from "@/components/PaginationNav.astro";
import GoogleAd from "@/components/GoogleAd.astro";
import { BLOG_INDEX_DESCRIPTION, BLOG_POSTS_PER_PAGE, BLOG_INTRO, NAV_HOME, NAV_SERIES, NAV_TAGS } from "@/consts";

const locale = Astro.currentLocale as Lang;
const t = useTranslations(locale);
const siteOrigin = Astro.site?.toString().replace(/\/$/, "") || "https://inaodeng.com";

const allPosts = (await getCollection("blog"))
  .filter((post) => post.id.split("/")[0] === locale)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const totalPosts = allPosts.length;
const totalPages = Math.max(1, Math.ceil(totalPosts / BLOG_POSTS_PER_PAGE));
const currentPage = 1;
const posts = allPosts.slice(0, BLOG_POSTS_PER_PAGE);

const title = t({ en: "Blog", "zh-cn": "博客" });
const description = t(BLOG_INDEX_DESCRIPTION);
const nextUrl = totalPages > 1 ? `${siteOrigin}/${locale}/blog/page/2/` : undefined;
const homeName = (typeof NAV_HOME === "string" ? NAV_HOME : NAV_HOME[locale]) ?? (locale === "zh-cn" ? "首页" : "Home");
const breadcrumbs = [
  { name: homeName, url: `/${locale}/` },
  { name: title, url: `/${locale}/blog/` },
];
const itemListSchema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  name: title,
  description,
  numberOfItems: totalPosts,
  itemListElement: posts.slice(0, 10).map((post, i) => {
    const [, ...idParts] = post.id.split("/");
    const slug = idParts.join("/").toLowerCase();
    return {
      "@type": "ListItem",
      position: i + 1,
      url: `${siteOrigin}/${locale}/blog/${slug}/`,
      name: post.data.title,
    };
  }),
};

export const getStaticPaths = () =>
  Object.keys(LOCALES).map((lang) => ({
    params: { lang },
  }));
---

<Layout {title} description={description} breadcrumbs={breadcrumbs} nextUrl={nextUrl}>
  <script type="application/ld+json" set:html={JSON.stringify(itemListSchema)} is:inline />
  <section class="blog-headline-wrap">
    <PageHeadline {title} compact>
      <p class="headline-intro">{t(BLOG_INTRO)}</p>
      <div class="headline-actions">
        <a href={getRelativeLocaleUrl(locale, "/series")} class="headline-btn">{t(NAV_SERIES)}</a>
        <a href={getRelativeLocaleUrl(locale, "/tags")} class="headline-btn">{t(NAV_TAGS)}</a>
      </div>
    </PageHeadline>
  </section>

  <div class="blog-container">
    <div class="post-grid">
      {
        posts.map((post) => {
          const [, ...id] = post.id.split("/");
          const postUrl = `/${locale}/blog/${id.join("/").toLowerCase()}/`;
          const dateStr = post.data.date.toLocaleDateString(
            locale === "zh-cn" ? "zh-CN" : "en-US",
            { year: "numeric", month: "short", day: "numeric" }
          );
          const descWords = post.data.description ? Math.ceil(post.data.description.length / 5) : 0;
          const estimatedWords = descWords > 0 ? descWords * 10 : 300;
          const readMins = Math.max(1, Math.ceil(estimatedWords / 200));
          const readLabel = locale === "zh-cn" ? `${readMins} 分钟阅读` : `${readMins} min read`;
          
          return (
            <article class="post-card">
              <a href={postUrl} class="post-link">
                <div class="post-content">
                  <time class="post-date">{dateStr}</time>
                  <h2 class="post-title">{post.data.title}</h2>
                  {post.data.description && <p class="post-desc">{post.data.description}</p>}
                </div>
              </a>
              
              <div class="post-footer">
                <span class="post-reading-time">{readLabel}</span>
                {post.data.tags && (
                  <div class="post-tags">
                    {post.data.tags.slice(0, 3).map((tag) => (
                      <a href={`/${locale}/tags/${tag.includes("/") || tag.includes(" ") ? encodeURIComponent(tag) : tag}/`} class="tag-link">
                        #{tag}
                      </a>
                    ))}
                  </div>
                )}
              </div>
            </article>
          );
        })
      }
    </div>
    {totalPages > 1 && (
      <PaginationNav {currentPage} {totalPages} {locale} />
    )}
    <GoogleAd />
  </div>
</Layout>

<style>
  .blog-container {
    margin-block-start: var(--sp-l);
  }

  .post-grid {
    display: grid;
    gap: var(--sp-m);
    grid-template-columns: repeat(auto-fill, minmax(20rem, 1fr));
  }

  @media (max-width: 960px) {
    .post-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 480px) {
    .post-grid {
      grid-template-columns: 1fr;
    }
  }

  .post-card {
    display: flex;
    flex-direction: column;
    border-radius: var(--radius-lg);
    overflow: hidden;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    transition: transform 0.25s cubic-bezier(0.4, 0, 0.2, 1),
                border-color 0.25s cubic-bezier(0.4, 0, 0.2, 1),
                box-shadow 0.25s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .post-card:hover {
    transform: translateY(-4px);
    border-color: var(--color-theme);
    box-shadow: 0 0 20px var(--glow-theme);
  }

  @media (prefers-reduced-motion: reduce) {
    .post-card:hover {
      transform: none;
    }
    .post-card {
      transition: border-color 0.25s cubic-bezier(0.4, 0, 0.2, 1),
                  box-shadow 0.25s cubic-bezier(0.4, 0, 0.2, 1);
    }
  }

  .post-link {
    text-decoration: none;
    color: inherit;
    flex-grow: 1;
  }

  .post-content {
    padding: var(--sp-m);
    flex-grow: 1;
  }

  .post-date {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--color-theme);
    opacity: 0.8;
    margin-block-end: 0.5rem;
    display: block;
  }

  .post-title {
    font-size: 1.25rem;
    font-weight: 800;
    line-height: 1.3;
    color: var(--color-main);
    margin-block-end: 0.75rem;
  }

  .post-desc {
    font-size: 0.9rem;
    line-height: 1.5;
    opacity: 0.7;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .post-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 0.5rem;
    padding: 0.75rem var(--sp-m);
    border-top: 1px solid var(--color-border);
  }

  .post-reading-time {
    font-size: var(--text-xs);
    opacity: 0.6;
    white-space: nowrap;
  }

  .post-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .tag-link {
    font-size: 0.75rem;
    font-weight: 700;
    color: var(--color-theme);
    text-decoration: none;
    padding: 0.2rem 0.5rem;
    border-radius: var(--radius-sm);
    background: color-mix(in srgb, var(--color-theme) 8%, transparent);
    transition: all 0.2s ease;
  }

  .tag-link:hover {
    background: var(--color-theme);
    color: white;
  }

  .headline-intro {
    margin: 0 auto;
    margin-block-start: 0.5rem;
    max-inline-size: 55rem; /* 880px，与博文详情页一致 */
    font-size: 0.875rem;
    line-height: 1.55;
    color: var(--color-main);
    opacity: 0.88;
    text-align: center;
  }

  .headline-actions {
    display: flex;
    justify-content: center;
    flex-wrap: wrap;
    gap: 0.625rem;
    margin-block-start: 0.875rem;
    padding-block-start: 0.75rem;
    border-block-start: 1px solid color-mix(in srgb, var(--color-theme) 18%, transparent);
  }

  .headline-btn {
    display: inline-flex;
    align-items: center;
    padding: 0.38rem 0.95rem;
    border-radius: 10px;
    background: color-mix(in srgb, var(--color-theme) 12%, transparent);
    border: 1px solid color-mix(in srgb, var(--color-theme) 35%, transparent);
    color: var(--color-theme);
    text-decoration: none;
    font-size: 0.825rem;
    font-weight: 600;
    letter-spacing: 0.02em;
    transition: all 0.22s ease;
  }

  .blog-headline-wrap :global(header.compact) {
    padding-top: 0.28rem !important;
    padding-bottom: 0.22rem !important;
  }

  .blog-headline-wrap :global(header.compact h1) {
    margin-top: 0 !important;
    margin-bottom: 0 !important;
    font-size: 1.38rem;
    line-height: 1.2;
  }

  .blog-headline-wrap :global(header.compact .headline-intro) {
    margin-top: 0.3rem !important;
    margin-bottom: 0 !important;
  }

  .blog-headline-wrap :global(header.compact .headline-actions) {
    margin-top: 0.55rem !important;
    padding-top: 0.48rem !important;
    margin-bottom: 0 !important;
  }

  .headline-btn:hover {
    background: var(--color-theme);
    color: var(--color-base);
    border-color: var(--color-theme);
    transform: translateY(-2px);
    box-shadow: 0 4px 12px -4px color-mix(in srgb, var(--color-theme) 35%, transparent);
  }

  .headline-btn:focus-visible {
    outline: 2px solid var(--color-theme);
    outline-offset: 2px;
  }
</style>
