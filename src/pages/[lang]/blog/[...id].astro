---
import Layout from "@/layouts/Article.astro";
import ArticleShare from "@/components/ArticleShare.astro";
import AuthorStatsCard from "@/components/AuthorStatsCard.astro";
import Giscus from "@/components/Giscus.astro";
import GoogleAd from "@/components/GoogleAd.astro";
import TableOfContents from "@/components/TableOfContents.astro";
import SidebarAd from "@/components/SidebarAd.astro";
import TrackingEvents from "@/components/TrackingEvents.astro";
import { getCollection, render } from "astro:content";
import { ARTICLE_LICENSE, NAV_HOME, READING_TIME_LABEL, SITE_SLOGAN } from "@/consts";
import type { Lang } from "@/i18n";
import { wikiIdToSlug, getTitleZhFromBody, getTitleZh, slugToTitleEn } from "@/data/wiki";
import { aiwikiIdToSlug, aiwikiIdToLang, getAiWikiDisplayTitle } from "@/data/aiwiki";

/** 根据正文字符数估算阅读时长（约 1000 字/分钟，至少 1 分钟） */
function readingTimeMinutes(rawBody: string): number {
  const text = rawBody.replace(/\s+/g, " ").trim();
  return Math.max(1, Math.ceil(text.length / 1000));
}

export async function getStaticPaths() {
  const posts = await getCollection("blog");
  return posts.map((post) => {
    const [lang, ...idParts] = post.id.split("/");
    // 博文 URL 路径段统一小写，避免大小写不一致导致 404
    const id = idParts.join("/").toLowerCase();
    return {
      params: { lang, id },
      props: post,
    };
  });
}

const { lang, id } = Astro.params;
const post = Astro.props;
const locale = (lang ?? "zh-cn") as Lang;
const siteOrigin = "https://inaodeng.com";
const postPath = `/${lang}/blog/${id ?? ""}/`;
const canonicalUrl = `${siteOrigin}${postPath}`;

const ogImageUrl = `${siteOrigin}/default.jpg`;

const { Content, headings = [] } = await render(post);
const tocLabel = locale === "zh-cn" ? "目录" : "Table of Contents";
const title = post.data.title;
const description = post.data.description;
const authorName = post.data.author || "Nao Deng";
const datePublished = post.data.date.toISOString();
const dateModified = post.data.updated ? new Date(post.data.updated).toISOString() : datePublished;

const rawBody = typeof post.body === "string" ? post.body : "";
const wordCount = rawBody.split(/\s+/).filter(Boolean).length;
const blogPostingSchema = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  headline: title,
  description,
  datePublished,
  dateModified,
  url: canonicalUrl,
  mainEntityOfPage: { "@type": "WebPage", "@id": canonicalUrl },
  image: { "@type": "ImageObject", url: ogImageUrl, width: 1200, height: 630 },
  inLanguage: locale === "zh-cn" ? "zh-CN" : "en",
  wordCount,
  author: { "@type": "Person", name: authorName, url: siteOrigin },
  publisher: {
    "@type": "Organization",
    name: "Nao's Blog",
    url: siteOrigin,
    logo: { "@type": "ImageObject", url: `${siteOrigin}/ogp.png`, width: 1200, height: 630 },
  },
};

const homeName = typeof NAV_HOME === "string" ? NAV_HOME : (NAV_HOME[locale] ?? (locale === "zh-cn" ? "首页" : "Home"));
const readMinutes = readingTimeMinutes(rawBody);
const readingTimeLabel = typeof READING_TIME_LABEL === "string" ? READING_TIME_LABEL : (READING_TIME_LABEL[locale] ?? (locale === "zh-cn" ? "分钟阅读" : "min read"));
const breadcrumbs = [
  { name: homeName, url: `/${lang}/` },
  { name: locale === "zh-cn" ? "博客" : "Blog", url: `/${lang}/blog/` },
  { name: title, url: postPath },
];

// 站点统计（用于侧栏作者卡片）
const allPosts = await getCollection("blog");
const totalArticles = allPosts.length;
const allCategories = new Set(allPosts.flatMap((p) => p.data.categories ?? []));
const allTags = new Set(allPosts.flatMap((p) => p.data.tags ?? []));
const totalChars = allPosts.reduce((sum, p) => sum + (typeof p.body === "string" ? p.body.length : 0), 0);
const authorSlogan = typeof SITE_SLOGAN === "string" ? SITE_SLOGAN : (SITE_SLOGAN[locale] ?? (locale === "zh-cn" ? "质量分析师，而非质量保证师。" : "Quality Analyst, Not Quality Assurance."));
const statsLabels = locale === "zh-cn"
  ? { articles: "文章", categories: "分类", tags: "标签", words: "字数" }
  : { articles: "Articles", categories: "Categories", tags: "Tags", words: "Words" };

type TermLink = { label: string; href: string; score: number };
const norm = (s: string) =>
  String(s || "")
    .toLowerCase()
    .replace(/[`*_~#()[\]{}|\\/:;,.!?'"“”‘’·\-]+/g, " ")
    .replace(/\s+/g, " ")
    .trim();

const signals = [
  title,
  ...(post.data.tags ?? []),
  ...(post.data.categories ?? []),
  ...(post.data.series ?? []),
]
  .map((x) => norm(String(x)))
  .filter(Boolean);

const allAiWiki = await getCollection("aiwiki");
const aiEntries = allAiWiki.filter((e) =>
  (e.data.lang ? e.data.lang === locale : aiwikiIdToLang(e.id) === locale)
);
const wikiEntries = locale === "zh-cn" ? await getCollection("wiki") : [];

const candidates: TermLink[] = [];
for (const e of aiEntries) {
  const slug = e.data.slug ?? aiwikiIdToSlug(e.id);
  const label = getAiWikiDisplayTitle(e, locale);
  const text = norm(`${slug} ${label}`);
  let score = 0;
  for (const s of signals) {
    if (!s || s.length < 2) continue;
    if (text === s) score = Math.max(score, 10);
    else if (text.includes(s) || s.includes(text)) score = Math.max(score, 6);
  }
  candidates.push({ label, href: `/${locale}/AIWiki/${slug}/`, score });
}

if (locale === "zh-cn") {
  for (const e of wikiEntries) {
    const slug = wikiIdToSlug(e.id);
    const label = getTitleZhFromBody(e.body) || getTitleZh(e.data.title ?? "") || slugToTitleEn(slug);
    const text = norm(`${slug} ${label}`);
    let score = 0;
    for (const s of signals) {
      if (!s || s.length < 2) continue;
      if (text === s) score = Math.max(score, 10);
      else if (text.includes(s) || s.includes(text)) score = Math.max(score, 6);
    }
    candidates.push({ label, href: `/${locale}/wiki/${slug}/`, score });
  }
}

const relatedTerms: TermLink[] = [];
const seenHref = new Set<string>();
for (const item of candidates.sort((a, b) => b.score - a.score || a.label.localeCompare(b.label, locale === "zh-cn" ? "zh-CN" : "en"))) {
  if (seenHref.has(item.href)) continue;
  seenHref.add(item.href);
  relatedTerms.push(item);
  if (relatedTerms.length >= 5) break;
}
---

<Layout
  title={title}
  description={description}
  image={ogImageUrl}
  imageAlt={title}
  articlePublishedTime={datePublished}
  articleModifiedTime={dateModified}
  articleAuthor={authorName}
  breadcrumbs={breadcrumbs}
  contentWide
>
  <script type="application/ld+json" set:html={JSON.stringify(blogPostingSchema)} is:inline />
  <div class="article-with-toc">
    <div class="article-body">
      <header class="article-title-header" id="article-title-header">
        <h1>{title}</h1>
        <p class="article-meta">
          <span class="meta-item">
            <span class="meta-icon" aria-hidden="true">
              <svg xmlns="http://www.w3.org/2000/svg" width="1em" height="1em" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
            </span>
            <time datetime={post.data.date.toISOString()}>
              {post.data.date.toLocaleDateString(lang)}
            </time>
          </span>
          <span class="meta-sep" aria-hidden="true">•</span>
          <span class="meta-item">
            <span class="meta-icon" aria-hidden="true">
              <svg xmlns="http://www.w3.org/2000/svg" width="1em" height="1em" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
            </span>
            <span>{readMinutes} {readingTimeLabel}</span>
          </span>
          <span class="meta-sep" aria-hidden="true">•</span>
          <span class="meta-item">
            <span class="meta-icon" aria-hidden="true">
              <svg xmlns="http://www.w3.org/2000/svg" width="1em" height="1em" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M14.83 14.83a4 4 0 1 1-5.66-5.66"/><path d="M12 12h.01"/></svg>
            </span>
            <span>{ARTICLE_LICENSE}</span>
          </span>
          {post.data.updated && (
            <>
              <span class="meta-sep" aria-hidden="true">•</span>
              <span class="meta-item">
                <span class="meta-icon" aria-hidden="true">
                  <svg xmlns="http://www.w3.org/2000/svg" width="1em" height="1em" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"/><path d="M3 3v5h5"/></svg>
                </span>
                <time datetime={dateModified}>
                  {locale === "zh-cn" ? "更新于 " : "Updated "}
                  {new Date(post.data.updated).toLocaleDateString(locale === "zh-cn" ? "zh-CN" : "en-US", { year: "numeric", month: "short", day: "numeric" })}
                </time>
              </span>
            </>
          )}
        </p>
        {
          post.data.tags && post.data.tags.length > 0 && (
            <div class="tags">
              {post.data.tags.slice(0, 3).map((tag) => {
                const tagSegment = tag.includes("/") || tag.includes(" ") ? encodeURIComponent(tag) : tag;
                const tagUrl = `/${lang}/tags/${tagSegment}/`;
                return (
                  <a href={tagUrl} class="tag">{tag}</a>
                );
              })}
            </div>
          )
        }
      </header>

      <div class="cover-wrap">
        <div class="cover-bg cover-bg--default" role="img" aria-hidden="true" />
        <div class="cover-overlay">
          <h2 class="cover-title">{title}</h2>
          <p class="cover-meta">
            <span class="cover-author">{authorName}</span>
            <span class="cover-sep">·</span>
            <time datetime={post.data.date.toISOString()}>{post.data.date.toLocaleDateString(lang)}</time>
          </p>
        </div>
      </div>

      <div class="article-main">
        <div class="prose">
          <Content class="material-icons" />
        </div>
        {relatedTerms.length > 0 && (
          <section class="blog-related-terms" aria-labelledby="blog-related-terms-heading">
            <h2 id="blog-related-terms-heading">
              {locale === "zh-cn" ? "相关术语" : "Related Terms"}
            </h2>
            <div class="blog-related-terms-pills">
              {relatedTerms.map((item) => (
                <a href={item.href} class="blog-related-terms-pill">{item.label}</a>
              ))}
            </div>
          </section>
        )}
        <GoogleAd />
        <ArticleShare title={title} url={canonicalUrl} locale={locale as "zh-cn" | "en"} />
        <Giscus
          lang={locale === "zh-cn" ? "zh-CN" : "en"}
          theme="preferred_color_scheme"
          inputPosition="bottom"
          reactionsEnabled={true}
          loading="lazy"
        />
      </div>
    </div>

    <aside class="article-sidebar" aria-label={locale === "zh-cn" ? "侧栏" : "Sidebar"}>
      <div class="article-sidebar-inner">
        <AuthorStatsCard
          avatarUrl="/favicon.svg"
          authorName={authorName}
          slogan={authorSlogan}
          authorLink={`/${lang}/`}
          stats={{ articles: totalArticles, categories: allCategories.size, tags: allTags.size, words: totalChars }}
          labels={statsLabels}
          social={{
            github: "https://github.com/naodeng",
            medium: "https://naodeng.medium.com/",
            x: "https://x.com/inaodeng",
            weibo: "https://weibo.com/u/1651778270",
            rss: `/${lang}/rss.xml`,
          }}
        />
        <TableOfContents headings={headings} label={tocLabel} placement="below" />
        <SidebarAd />
      </div>
    </aside>
  </div>
</Layout>
<TrackingEvents mode="detail" locale={locale} channel="blog" slug={String(id ?? "")} detailLinkSelector=".blog-related-terms-pill" />

<style>
  /* 主内容保持 800px，侧栏在右侧额外空间，不占用正文区域 */
  .article-with-toc {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--sp-l);
    align-items: start;
  }
  @media (min-width: 960px) {
    .article-with-toc {
      /* 正文区 900px，侧栏 300px */
      grid-template-columns: minmax(0, 900px) 300px;
      gap: 2.5rem;
      justify-content: start;
    }
    .article-sidebar {
      align-self: start;
      height: var(--article-prose-height, auto);
      margin-inline-start: 6%;
      min-height: 0;
    }
    .article-sidebar-inner {
      position: sticky;
      top: var(--sp-m, 1rem);
      display: flex;
      flex-direction: column;
      gap: 1.5rem;
      max-height: calc(100vh - var(--sp-m, 1rem) * 2);
      overflow-y: auto;
      padding-inline-end: 0.25rem;
      scrollbar-width: none;
      -ms-overflow-style: none;
    }
    .article-sidebar-inner::-webkit-scrollbar {
      display: none;
    }
  }
  .article-body {
    width: 100%;
    min-width: 0;
    max-inline-size: 900px;
    margin-inline: auto;
    box-sizing: border-box;
  }
  .article-sidebar {
    min-width: 0;
  }
  .article-sidebar-inner {
    min-width: 0;
  }
  header {
    text-align: center;
    border-block-end: none;
    padding-block-end: var(--sp-m);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
  }
  header h1 {
    color: var(--color-theme);
    font-size: 1.8rem;
    margin: 0;
  }
  .article-meta {
    margin: 0;
    font-size: 0.9rem;
    color: color-mix(in srgb, var(--color-main) 70%, transparent);
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: 0.35rem 0.75rem;
  }
  .meta-item {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
  }
  .meta-icon {
    display: inline-flex;
    flex-shrink: 0;
    color: var(--color-theme);
    opacity: 0.9;
  }
  .meta-icon svg {
    vertical-align: middle;
  }
  .meta-sep {
    color: color-mix(in srgb, var(--color-main) 40%, transparent);
    user-select: none;
    font-weight: 300;
  }
  .cover-wrap {
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 7.2;
    overflow: hidden;
    border-radius: 20px;
    margin-block-end: var(--sp-m);
    box-shadow: 0 4px 20px rgba(0,0,0,0.12);
  }
  .cover-bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .cover-bg--default {
    background-image: url("/default.jpg");
    background-size: cover;
    background-position: center;
    background-color: #1a1a1f;
    filter: blur(3px);
    transform: scale(1.06);
  }
  .cover-overlay {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    padding: 2rem 2rem;
    background: rgba(0,0,0,0.52);
    color: #fff;
    text-shadow: 0 1px 3px rgba(0,0,0,0.6);
    text-align: center;
  }
  .cover-title {
    margin: 0 0 0.4em 0;
    font-size: 1.6rem;
    font-weight: 700;
    line-height: 1.3;
    max-width: 100%;
    letter-spacing: 0.02em;
  }
  .cover-meta {
    margin: 0;
    font-size: 0.875rem;
    opacity: 0.95;
    font-weight: 500;
  }
  .cover-sep {
    margin-inline: 0.5em;
    opacity: 0.85;
  }
  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    justify-content: center;
    margin-block-start: 0.5rem;
  }
  .tag {
    display: inline-flex;
    align-items: center;
    min-height: 44px;
    background-color: var(--color-theme);
    color: white;
    padding: 0.35rem 0.75rem;
    border-radius: 4px;
    font-size: 0.875rem;
    text-decoration: none;
    transition: opacity 0.2s ease, transform 0.2s ease;
  }
  .tags a.tag:hover {
    opacity: 0.9;
    transform: translateY(-1px);
  }
  .tags a.tag:focus-visible {
    outline: 2px solid var(--color-theme);
    outline-offset: 2px;
  }
  .article-main {
    margin-block-start: var(--sp-l);
    min-width: 0;
  }
  .blog-related-terms {
    margin: 1.25rem 0 1rem;
    padding: 0.9rem 1rem;
    border: 1px solid color-mix(in srgb, var(--color-theme) 30%, transparent);
    border-radius: 14px;
    background: color-mix(in srgb, var(--color-theme) 8%, transparent);
  }
  .blog-related-terms h2 {
    margin: 0 0 0.75rem;
    font-size: 1rem;
    line-height: 1.2;
    color: var(--color-theme);
  }
  .blog-related-terms-pills {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }
  .blog-related-terms-pill {
    display: inline-flex;
    align-items: center;
    padding: 0.32rem 0.62rem;
    border-radius: 999px;
    border: 1px solid color-mix(in srgb, var(--color-theme) 45%, transparent);
    background: color-mix(in srgb, var(--color-theme) 12%, transparent);
    color: color-mix(in srgb, var(--color-main) 92%, transparent);
    text-decoration: none;
    font-size: 0.86rem;
    font-weight: 600;
    transition: all 0.2s ease;
  }
  .blog-related-terms-pill:hover {
    color: var(--color-base);
    background: var(--color-theme);
    border-color: var(--color-theme);
  }

  /* Markdown / 正文内容样式 */
  .prose {
    font-size: 1rem;
    line-height: 1.75;
    color: var(--color-main);
  }
  .prose :global(h2) {
    font-size: 1.4rem;
    font-weight: 700;
    margin-block: 1.5em 0.5em;
    padding-block-end: 0.3em;
    border-block-end: 1px solid color-mix(in srgb, var(--color-theme) 30%, transparent);
    color: var(--color-theme);
  }
  .prose :global(h2:first-child) {
    margin-block-start: 0;
  }
  .prose :global(h3) {
    font-size: 1.2rem;
    font-weight: 700;
    margin-block: 1.25em 0.4em;
    color: var(--color-main);
  }
  .prose :global(h4) {
    font-size: 1.1rem;
    font-weight: 600;
    margin-block: 1em 0.35em;
    color: var(--color-main);
  }
  .prose :global(p) {
    margin-block: 0.85em 0;
  }
  .prose :global(ul),
  .prose :global(ol) {
    margin-block: 0.85em 0;
    padding-inline-start: 1.5em;
  }
  .prose :global(ul) {
    list-style-type: disc;
  }
  .prose :global(ol) {
    list-style-type: decimal;
  }
  .prose :global(li) {
    margin-block: 0.35em 0;
  }
  .prose :global(li > p) {
    margin-block: 0.25em 0;
  }
  .prose :global(blockquote) {
    margin-block: 1em 0;
    padding-inline-start: 1em;
    border-inline-start: 4px solid var(--color-theme);
    color: color-mix(in srgb, var(--color-main) 85%, transparent);
    font-style: italic;
  }
  .prose :global(pre) {
    margin-block: 1em 0;
    padding: 1rem 1.25rem;
    overflow-x: auto;
    border-radius: 8px;
    background: color-mix(in srgb, var(--color-main) 8%, transparent);
    border: 1px solid color-mix(in srgb, var(--color-theme) 20%, transparent);
    font-size: 0.9rem;
    line-height: 1.5;
  }  .prose :global(code) {
    font-family: ui-monospace, "Cascadia Code", "Source Code Pro", Menlo, Consolas, monospace;
    font-size: 0.9em;
    padding: 0.15em 0.4em;
    border-radius: 4px;
    background: color-mix(in srgb, var(--color-main) 12%, transparent);
    border: 1px solid color-mix(in srgb, var(--color-theme) 15%, transparent);
  }
  .prose :global(pre code) {
    padding: 0;
    background: none;
    border: none;
    font-size: inherit;
  }
  .prose :global(strong) {
    font-weight: 700;
    color: var(--color-main);
  }
  .prose :global(a) {
    color: var(--color-theme);
    text-decoration: underline;
  }
  .prose :global(a:hover) {
    text-decoration-thickness: 2px;
  }
  .prose :global(img) {
    max-width: 100%;
    height: auto;
    border-radius: 8px;
    display: block;
    margin-block: 1em 0;
  }
  .prose :global(hr) {
    margin-block: 1.5em 0;
    border: none;
    border-block-start: 1px solid color-mix(in srgb, var(--color-theme) 25%, transparent);
  }
  .prose :global(table) {
    width: 100%;
    margin-block: 1em 0;
    border-collapse: collapse;
    font-size: 0.95rem;
  }
  .prose :global(th),
  .prose :global(td) {
    padding: 0.5rem 0.75rem;
    border: 1px solid color-mix(in srgb, var(--color-theme) 20%, transparent);
    text-align: start;
  }
  .prose :global(th) {
    background: color-mix(in srgb, var(--color-theme) 12%, transparent);
    font-weight: 600;
  }
  @media (max-width: 959px) {
    .article-sidebar {
      height: auto !important;
      margin-inline-start: 0;
    }
    .article-sidebar-inner {
      position: static;
      max-height: none;
      overflow: visible;
      padding-inline-end: 0;
    }
  }
</style>

<script>
  function syncSidebarHeightToProse() {
    const sidebar = document.querySelector(".article-sidebar") as HTMLElement | null;
    const prose = document.querySelector(".article-main .prose") as HTMLElement | null;
    if (!sidebar || !prose) return;
    if (window.innerWidth < 960) {
      sidebar.style.removeProperty("--article-prose-height");
      return;
    }
    sidebar.style.setProperty("--article-prose-height", `${Math.ceil(prose.offsetHeight)}px`);
  }

  document.addEventListener("DOMContentLoaded", syncSidebarHeightToProse);
  window.addEventListener("load", syncSidebarHeightToProse);
  window.addEventListener("resize", syncSidebarHeightToProse);
  if (typeof ResizeObserver !== "undefined") {
    const prose = document.querySelector(".article-main .prose");
    if (prose) new ResizeObserver(syncSidebarHeightToProse).observe(prose);
  }
</script>
