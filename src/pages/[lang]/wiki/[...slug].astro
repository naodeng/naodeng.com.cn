---
/**
 * 测试百科词条页（docs 布局：左侧导航 + 主内容）
 * - 中文：Docs 布局，侧栏高亮当前词条，主区渲染正文
 * - 英文：重定向 https://ray.run/wiki
 */
import { getCollection, render } from "astro:content";
import DocsLayout from "@/layouts/Docs.astro";
import Giscus from "@/components/Giscus.astro";
import GoogleAd from "@/components/GoogleAd.astro";
import { NAV_HOME } from "@/consts";
import { slugToTitleEn, getTitleZhFromBody, getTitleZh, buildWikiSidebar, wikiIdToSlug } from "@/data/wiki";
import type { Lang } from "@/i18n";

export async function getStaticPaths() {
  const entries = await getCollection("wiki");
  return entries.map((entry) => {
    const slug = wikiIdToSlug(entry.id);
    return {
      params: { lang: "zh-cn", slug },
      props: { entry },
    };
  });
}

const { entry } = Astro.props;
const locale = (Astro.params.lang ?? "zh-cn") as Lang;
const slugParam = (Astro.params.slug ?? "") as string;

if (locale === "en") {
  const url = new URL("https://ray.run/wiki");
  if (slugParam) url.hash = slugParam;
  return Astro.redirect(url.toString());
}

const homeName = (typeof NAV_HOME === "string" ? NAV_HOME : NAV_HOME[locale]) ?? "首页";
const wikiTitle = "测试百科";
const bodyStr = typeof entry.body === "string" ? entry.body : "";
const pageTitle =
  getTitleZhFromBody(bodyStr) || getTitleZh(entry.data?.title ?? "") || slugToTitleEn(slugParam) || entry.data?.title || slugParam;
const rawDescription =
  (entry.data?.description && String(entry.data.description).trim()) ||
  (bodyStr && bodyStr.replace(/^#.+/m, "").replace(/[#*_[\]()`]/g, "").trim().slice(0, 200)) ||
  pageTitle;
const metaDescription = rawDescription.length > 155 ? rawDescription.slice(0, 152).trimEnd() + "…" : rawDescription;
const breadcrumbs = [
  { name: homeName, url: `/${locale}/` },
  { name: wikiTitle, url: `/${locale}/wiki/` },
  { name: pageTitle, url: `/${locale}/wiki/${slugParam}/` },
];

const entries = await getCollection("wiki");
const sidebarSections = buildWikiSidebar(entries);
const basePath = `/${locale}/wiki`;

const { Content, headings: renderedHeadings = [] } = await render(entry);

// Astro 5 glob loader 对 .md 文件 render() 不返回 headings，手动从 body 解析
function parseHeadings(body: string): { depth: number; slug: string; text: string }[] {
  const lines = body.split("\n");
  const result: { depth: number; slug: string; text: string }[] = [];
  for (const line of lines) {
    const m = line.match(/^(#{2,3})\s+(.+)$/);
    if (m) {
      const depth = m[1].length;
      const text = m[2].trim();
      const slug = text.toLowerCase().replace(/[^\w\u4e00-\u9fff\s-]/g, "").replace(/\s+/g, "-").replace(/-+/g, "-").replace(/^-|-$/g, "");
      result.push({ depth, slug, text });
    }
  }
  return result;
}
const headings = renderedHeadings.length > 0 ? renderedHeadings : parseHeadings(bodyStr);

const siteOrigin = Astro.site?.toString().replace(/\/$/, "") || "https://inaodeng.com";
const wikiPageUrl = `${siteOrigin}/${locale}/wiki/${slugParam}/`;
const definedTermSchema = {
  "@context": "https://schema.org",
  "@type": "DefinedTerm",
  name: pageTitle,
  description: metaDescription,
  url: wikiPageUrl,
  inDefinedTermSet: {
    "@type": "DefinedTermSet",
    name: "软件测试百科",
    url: `${siteOrigin}/${locale}/wiki/`,
  },
};
---

<DocsLayout
  title={pageTitle}
  description={metaDescription}
  breadcrumbs={breadcrumbs}
  structuredData={[definedTermSchema]}
  sidebarSections={sidebarSections}
  currentPath={slugParam}
  basePath={basePath}
  sidebarMenuLabel="本页导航"
  headings={headings}
  tocLabel="本页目录"
>
  <article class="wiki-article">
    <Content />
    {entry.data.related && entry.data.related.length > 0 && (
      <section class="wiki-related" aria-labelledby="wiki-related-heading">
        <h2 id="wiki-related-heading" class="wiki-related-title">相关词条</h2>
        <div class="wiki-related-pills">
          {entry.data.related.map((term: string) => (
            <a href={`${basePath}/${term}/`} class="wiki-related-pill">{term}</a>
          ))}
        </div>
      </section>
    )}
  </article>
  <GoogleAd />
  <Giscus lang="zh-CN" inputPosition="bottom" />
</DocsLayout>

<script>
  // Scroll the active sidebar link into view on page load
  const activeLink = document.querySelector<HTMLAnchorElement>(".docs-sidebar-link--active");
  if (activeLink) {
    activeLink.scrollIntoView({ block: "nearest", behavior: "instant" });
  }
</script>

<style>
  .wiki-article {
    max-inline-size: 68ch;
    line-height: 1.8;
  }

  .wiki-article :global(h1) {
    font-size: var(--text-xl);
    padding-block-end: var(--sp-s);
    border-block-end: 2px solid var(--color-theme);
    margin-block-end: var(--sp-m);
  }

  .wiki-article :global(h2) {
    font-size: clamp(1.45rem, 2.4vw, 1.75rem);
    font-weight: 700;
    border-inline-start: 5px solid var(--color-theme);
    background: color-mix(in srgb, var(--color-theme) 8%, transparent);
    border-radius: 0 var(--radius-sm) var(--radius-sm) 0;
    padding: 0.25em 0.6em 0.25em var(--sp-s);
    margin-block: 2.2em 0.7em;
  }

  .wiki-article :global(h3) {
    font-size: clamp(1.2rem, 2vw, 1.35rem);
    font-weight: 650;
    border-inline-start: 2px solid color-mix(in srgb, var(--color-theme) 35%, var(--color-border));
    padding-inline-start: 0.6em;
    margin-block: 1.6em 0.5em;
  }

  .wiki-article :global(h4) {
    font-size: 1.05rem;
    font-weight: 600;
    color: color-mix(in srgb, var(--color-main) 88%, transparent);
    margin-block: 1.2em 0.4em;
  }

  .wiki-article :global(h4::before) {
    content: "•";
    color: color-mix(in srgb, var(--color-theme) 72%, transparent);
    margin-inline-end: 0.45em;
  }

  .wiki-article :global(a) {
    color: var(--color-theme);
    text-decoration: underline;
  }

  .wiki-article :global(ul) {
    padding-inline-start: 1.5em;
  }

  .wiki-related {
    margin-block-start: var(--sp-l);
    padding-block-start: var(--sp-m);
    border-block-start: 1px solid var(--color-border);
  }

  .wiki-related-title {
    font-size: var(--text-lg);
    font-weight: 600;
    margin-block-end: var(--sp-s);
    /* override the h2 accent border from above */
    background: none;
    border-radius: 0;
    border-inline-start: none;
    padding: 0;
    border-block-end: none;
  }

  .wiki-related-pills {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .wiki-related-pill {
    display: inline-block;
    padding: 0.3em 0.75em;
    border: 1px solid var(--color-theme);
    border-radius: var(--radius-sm);
    color: var(--color-theme);
    text-decoration: none;
    font-size: var(--text-sm);
    transition: background-color 0.2s, color 0.2s;
  }

  .wiki-related-pill:hover {
    background-color: var(--color-theme);
    color: #fff;
  }
</style>
